@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SmartTab Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --st-purple: #6f00ff;
            --st-purple-hover: #5b00d6;
        }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; background-color: #f8f9fa; }
        .bg-st-purple { background-color: var(--st-purple); }
        .hover\:bg-st-purple-hover:hover { background-color: var(--st-purple-hover); }
        .text-st-purple { color: var(--st-purple); }
        .border-st-purple { border-color: var(--st-purple); }
        
        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #f1f1f1; border-radius: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #c1c1c1; border-radius: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #a8a8a8; }
        
        input:focus, select:focus, textarea:focus { 
            outline: none; 
            border-color: var(--st-purple); 
            box-shadow: 0 0 0 2px rgba(111, 0, 255, 0.1); 
        }

        .checkbox-custom:checked {
            background-color: var(--st-purple);
            border-color: var(--st-purple);
        }
        .checkbox-custom:disabled {
            background-color: #e5e7eb;
            border-color: #d1d5db;
            cursor: not-allowed;
        }
    </style>
</head>
<body class="text-gray-800">
    <div class="min-h-screen flex flex-col">
        <header class="bg-black border-b border-gray-900 sticky top-0 z-50 shadow-md text-white">
            <div class="max-w-[1400px] mx-auto px-4 h-[70px] flex items-center justify-between gap-4">
                <div class="flex items-center gap-4 shrink-0">
                    <button class="text-2xl hover:text-st-purple transition-colors"><i class="fas fa-bars"></i></button>
                    <div class="flex items-center text-st-purple text-2xl font-bold tracking-tight cursor-pointer">
                        <i class="fas fa-layer-group mr-2 text-2xl"></i>
                        <span>SmartTab <span class="text-white font-black">Admin</span></span>
                    </div>
                </div>

                <div class="flex-1 max-w-xl mx-8 relative hidden md:block flex items-center">
                    <input type="text" id="searchInput" placeholder="Я шукаю..." 
                           class="w-full py-2.5 px-4 pr-[100px] rounded border-none text-sm focus:ring-2 focus:ring-st-purple text-black bg-white outline-none" 
                           onkeyup="filterProducts()">
                    <button class="absolute right-0 top-0 h-full px-6 bg-st-purple hover:bg-st-purple-hover transition-colors text-white text-sm font-medium rounded-r">
                        Знайти
                    </button>
                </div>
                
                <div class="w-[24px]"></div>
            </div>
        </header>

        <main class="max-w-[1400px] mx-auto w-full px-4 py-8">
            <div class="bg-white p-6 rounded shadow-sm mb-8 border border-gray-100">
                <h2 class="text-xl font-bold mb-6 text-gray-900 border-b-2 border-st-purple inline-block pb-1" id="form-title">
                    Додати товар
                </h2>
                
                <form id="product-form">
                    <input type="hidden" id="productId" value="">
                    
                    <div class="flex flex-col md:flex-row gap-6">
                        <div class="w-full md:w-[200px] shrink-0">
                            <div class="border-2 border-dashed border-gray-300 rounded w-full h-[200px] flex flex-col items-center justify-center text-gray-500 hover:border-st-purple cursor-pointer relative bg-gray-50 transition-colors group">
                                <input id="imageInput" type="file" class="absolute inset-0 opacity-0 cursor-pointer z-10" accept="image/*" onchange="previewImage(this)">
                                <div id="uploadPlaceholder" class="text-center group-hover:text-st-purple transition-colors">
                                    <span class="block text-sm font-medium">Додати<br>фото</span>
                                </div>
                                <img id="imagePreview" src="" class="hidden w-full h-full object-contain p-2">
                            </div>
                        </div>

                        <div class="flex-1 flex flex-col gap-4">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <select id="productType" class="border border-gray-300 rounded p-2.5 text-sm w-full bg-white text-gray-700" onchange="handleProductTypeChange()">
                                    <option value="0">Компонент (Component)</option>
                                    <option value="1">Готовий ПК</option>
                                </select>
                                <input type="number" id="price" step="0.01" min="0" class="border border-gray-300 rounded p-2.5 text-sm w-full" placeholder="Ціна (₴)">
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <input type="text" id="name" class="border border-gray-300 rounded p-2.5 text-sm w-full" placeholder="Назва товару">
                                <input type="number" id="stockCount" min="0" class="border border-gray-300 rounded p-2.5 text-sm w-full" placeholder="Кількість на складі">
                            </div>

                            <input type="number" id="initialQuantity" min="0" class="border border-gray-300 rounded p-2.5 text-sm w-full" placeholder="Початкова кількість (для генерації серійних номерів)">
                            
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-2">
                                <div class="border border-gray-200 rounded p-3 bg-gray-50/50">
                                    <label class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-2 block">Категорія</label>
                                    <div id="categoryCheckboxes" class="max-h-32 overflow-y-auto space-y-2 custom-scrollbar pr-2">
                                    </div>
                                </div>
                                <div class="border border-gray-200 rounded p-3 bg-gray-50/50">
                                    <label class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-2 block">Виробник</label>
                                    <div id="manufacturerCheckboxes" class="max-h-32 overflow-y-auto space-y-2 custom-scrollbar pr-2">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="dynamicSection" class="hidden mt-8 pt-6 border-t border-dashed border-gray-200">
                        <h3 id="dynamicTitle" class="font-bold text-gray-900 mb-4 text-sm">Характеристики:</h3>
                        <div id="dynamicGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 text-sm text-gray-600">
                        </div>
                    </div>

                    <div class="mt-8 flex gap-3">
                        <button type="button" id="submitBtn" onclick="addProduct()" class="flex-1 bg-st-purple hover:bg-st-purple-hover text-white font-medium py-2.5 px-6 rounded transition-colors text-sm">
                            Додати до каталогу
                        </button>
                        <button type="button" id="cancelBtn" onclick="resetForm()" class="hidden bg-gray-200 hover:bg-gray-300 text-gray-700 font-medium py-2.5 px-6 rounded transition-colors text-sm">
                            Скасувати
                        </button>
                    </div>
                </form>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-8">
                <div class="bg-white rounded shadow-sm border border-gray-100 p-5">
                    <h2 class="text-sm font-bold mb-4 text-gray-900 flex items-center">
                        <i class="fas fa-tags text-st-purple mr-2"></i> Керування категоріями
                    </h2>
                    <form id="category-form" class="space-y-3">
                        <input type="hidden" id="editCategoryId" value="">
                        <input type="text" id="categoryNameInput" class="w-full border border-gray-300 rounded p-2 text-sm" placeholder="Назва категорії">
                        <div class="flex gap-2">
                            <button type="button" id="categorySubmitBtn" onclick="addCategory()" class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-800 font-medium py-2 rounded transition-colors text-sm">
                                Зберегти
                            </button>
                            <button type="button" id="categoryCancelBtn" onclick="resetCategoryForm()" class="hidden bg-gray-100 hover:bg-gray-200 text-gray-600 px-3 rounded text-sm">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    </form>
                    <div id="categories-list" class="mt-4 space-y-1 max-h-[200px] overflow-y-auto custom-scrollbar pr-2 text-sm"></div>
                </div>

                <div class="bg-white rounded shadow-sm border border-gray-100 p-5 lg:col-span-2">
                    <h2 class="text-sm font-bold mb-4 text-gray-900 flex items-center">
                        <i class="fas fa-industry text-st-purple mr-2"></i> Керування виробниками
                    </h2>
                    <div class="flex flex-col md:flex-row gap-6">
                        <form id="manufacturer-form" class="flex-1 space-y-3">
                            <input type="hidden" id="editManufacturerId" value="">
                            <input type="text" id="manufacturerNameInput" class="w-full border border-gray-300 rounded p-2 text-sm" placeholder="Назва виробника">
                            <textarea id="manufacturerDescInput" rows="2" class="w-full border border-gray-300 rounded p-2 text-sm" placeholder="Опис виробника (необов'язково)"></textarea>
                            <div class="flex gap-2">
                                <button type="button" id="manufacturerSubmitBtn" onclick="addManufacturer()" class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-800 font-medium py-2 rounded transition-colors text-sm">
                                    Зберегти виробника
                                </button>
                                <button type="button" id="manufacturerCancelBtn" onclick="resetManufacturerForm()" class="hidden bg-gray-100 hover:bg-gray-200 text-gray-600 px-3 rounded text-sm">
                                    <i class="fas fa-times"></i>
                                </button>
                            </div>
                        </form>
                        <div class="flex-1">
                            <div id="manufacturers-list" class="space-y-1 max-h-[200px] overflow-y-auto custom-scrollbar pr-2 text-sm"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded shadow-sm border border-gray-100 p-6">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-xl font-bold text-gray-900">Всі товари <span id="product-count-label" class="text-gray-400 font-normal ml-2 text-sm"></span></h2>
                </div>
                
                <div id="products-grid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-6">
                </div>
            </div>
        </main>
    </div>

    <script>
        const categoryKeyByName = {
            'Готовий ПК': 'pc',
            'Готові ПК': 'pc',
            'Процесор': 'cpu',
            'Процесори': 'cpu',
            'Процесор (CPU)': 'cpu',
            'Відеокарта': 'gpu',
            'Відеокарти': 'gpu',
            'Відеокарта (GPU)': 'gpu',
            'Материнська плата': 'motherboard',
            'Материнські плати': 'motherboard',
            'Материнська плата (Motherboard)': 'motherboard',
            'ОЗП': 'ram',
            'Оперативна пам\'ять': 'ram',
            'Оперативна пам\'ять (RAM)': 'ram',
            'SSD': 'ssd',
            'Накопичувач (SSD)': 'ssd',
            'Накопичувачі (SSD)': 'ssd',
            'Накопичувачі (SSD/HDD)': 'ssd', 
            'HDD': 'hdd',
            'Накопичувач (HDD)': 'hdd',
            'Накопичувачі (HDD)': 'hdd',
            'Блок живлення': 'psu',
            'Блоки живлення': 'psu',
            'Блок живлення (PSU)': 'psu',
            // ДОДАНО НОВІ КЛЮЧІ ДЛЯ ОХОЛОДЖЕННЯ ТА КОРПУСУ
            'Охолодження': 'cooler',
            'Кулери': 'cooler',
            'Корпус': 'case',
            'Корпуси': 'case'
        };

        const specsSchema = {
            pc: [
                { id: 'cpu', label: 'Процесор' }, { id: 'gpu', label: 'Відеокарта' },
                { id: 'motherboard', label: 'Материнська плата' }, { id: 'cooler', label: 'Охолодження' },
                { id: 'ram', label: 'ОЗП' }, { id: 'storage', label: 'Накопичувач' },
                { id: 'psu', label: 'Блок живлення' }, { id: 'case', label: 'Корпус' }
            ],
            cpu: [
                { id: 'cores', label: 'Кількість ядер' }, { id: 'threads', label: 'Кількість потоків' },
                { id: 'socket', label: 'Сокет' }, { id: 'tdp', label: 'TDP (Вт)' },
                { id: 'frequency', label: 'Частота (ГГц)' }
            ],
            gpu: [
                { id: 'vram', label: "Об'єм пам'яті (ГБ)" }, { id: 'memoryType', label: "Тип пам'яті" },
                { id: 'tdp', label: 'Енергоспоживання (Вт)' }
            ],
            motherboard: [
                { id: 'socket', label: 'Сокет' }, { id: 'chipset', label: 'Чипсет' },
                { id: 'formFactor', label: 'Форм-фактор' }, { id: 'memoryType', label: "Тип пам'яті" }
            ],
            ram: [
                { id: 'capacity', label: "Об'єм (ГБ)" }, { id: 'type', label: "Тип пам'яті" },
                { id: 'frequency', label: 'Частота (МГц)' }, { id: 'latency', label: 'Таймінги (CL)' }
            ],
            ssd: [
                { id: 'capacity', label: "Об'єм (ГБ/ТБ)" }, { id: 'formFactor', label: 'Форм-фактор (2.5"/M.2)' },
                { id: 'interface', label: 'Інтерфейс (SATA/NVMe)' }, { id: 'readSpeed', label: 'Швидкість читання (МБ/с)' }
            ],
            hdd: [
                { id: 'capacity', label: "Об'єм (ГБ/ТБ)" }, { id: 'rpm', label: 'Швидкість шпинделя (об/хв)' },
                { id: 'buffer', label: 'Буфер (МБ)' }, { id: 'interface', label: 'Інтерфейс' }
            ],
            psu: [
                { id: 'power', label: 'Потужність (Вт)' }, { id: 'certification', label: 'Сертифікат (80+)' },
                { id: 'formFactor', label: 'Форм-фактор (ATX/SFX)' }
            ],
            // ДОДАНО СХЕМИ ДЛЯ НОВИХ КАТЕГОРІЙ
            cooler: [
                { id: 'type', label: 'Тип (Повітряне/Водяне)' }, { id: 'socket', label: 'Підтримувані сокети' }
            ],
            case: [
                { id: 'formFactor', label: 'Форм-фактор (ATX/Mini-ITX)' }
            ]
        };

        let allProducts = [];
        let allCategories = [];
        let allManufacturers = [];

        document.addEventListener('DOMContentLoaded', loadData);

        function previewImage(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    document.getElementById('imagePreview').src = e.target.result;
                    document.getElementById('imagePreview').classList.remove('hidden');
                    document.getElementById('uploadPlaceholder').classList.add('hidden');
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        // ХЕЛПЕР: функція для зручного читання JSON характеристик без дублювання коду
        function parseSpecs(opt) {
            if (!opt || !opt.dataset || !opt.dataset.specs) return {};
            try {
                let s = JSON.parse(opt.dataset.specs);
                if (Array.isArray(s)) {
                    let temp = {};
                    s.forEach(c => temp[c.name || c.label] = c.value);
                    return temp;
                }
                return s;
            } catch(e) {
                return {};
            }
        }

        function getSelectedId(name) {
            const el = document.querySelector(`input[name="${name}"]:checked`);
            return el ? el.value : '';
        }

        function handleProductTypeChange() {
            const type = document.getElementById('productType').value;
            const pcCategory = allCategories.find(c => categoryKeyByName[c.name] === 'pc');
            const smartTabMfg = allManufacturers.find(m => m.name.toLowerCase() === 'smarttab');
            
            const checkboxes = document.querySelectorAll('input[name="productCategory"]');
            const mfgCheckboxes = document.querySelectorAll('input[name="productManufacturer"]');
            
            if (type === '1') {
                if (pcCategory) {
                    checkboxes.forEach(cb => {
                        if (cb.value == pcCategory.id) {
                            cb.checked = true;
                            cb.disabled = false;
                            renderDynamicFields(cb.value);
                        } else {
                            cb.checked = false;
                            cb.disabled = true; 
                        }
                    });
                }
                
                mfgCheckboxes.forEach(cb => {
                    if (smartTabMfg && cb.value == smartTabMfg.id) {
                        cb.checked = true;
                        cb.disabled = true;
                    } else {
                        cb.checked = false;
                        cb.disabled = true;
                    }
                });

                if (smartTabMfg) {
                    document.getElementById('manufacturerNameInput').value = smartTabMfg.name;
                    document.getElementById('manufacturerDescInput').value = smartTabMfg.description || '';
                } else {
                    document.getElementById('manufacturerNameInput').value = '';
                    document.getElementById('manufacturerDescInput').value = '';
                }
            } else {
                let wasPcChecked = false;
                checkboxes.forEach(cb => {
                    cb.disabled = false; 
                    if (pcCategory && cb.value == pcCategory.id && cb.checked) {
                        cb.checked = false;
                        wasPcChecked = true;
                    }
                });
                
                mfgCheckboxes.forEach(cb => {
                    if (smartTabMfg && cb.value == smartTabMfg.id) {
                        cb.checked = false;
                        cb.disabled = true; 
                    } else {
                        cb.disabled = false;
                    }
                });

                if (document.getElementById('manufacturerNameInput').value.toLowerCase() === 'smarttab') {
                    document.getElementById('manufacturerNameInput').value = '';
                    document.getElementById('manufacturerDescInput').value = '';
                }

                if (wasPcChecked) renderDynamicFields('');
            }
        }

        function handleCategoryCheckbox(checkbox) {
            document.querySelectorAll('input[name="productCategory"]').forEach(cb => {
                if (cb !== checkbox) cb.checked = false;
            });

            const pcCategory = allCategories.find(c => categoryKeyByName[c.name] === 'pc');
            const typeSelect = document.getElementById('productType');
            
            if (checkbox.checked && pcCategory && checkbox.value == pcCategory.id) {
                typeSelect.value = '1';
                handleProductTypeChange(); 
                return;
            } else {
                typeSelect.value = '0';
                document.querySelectorAll('input[name="productCategory"]').forEach(cb => cb.disabled = false);
                document.querySelectorAll('input[name="productManufacturer"]').forEach(cb => cb.disabled = false);
            }
            
            renderDynamicFields(checkbox.checked ? checkbox.value : '');
        }

        function handleManufacturerCheckbox(checkbox) {
            document.querySelectorAll('input[name="productManufacturer"]').forEach(cb => {
                if (cb !== checkbox) cb.checked = false;
            });
            const selectedManufacturerId = getSelectedId('productManufacturer');
            if (selectedManufacturerId) {
                const manufacturer = allManufacturers.find(m => m.id == selectedManufacturerId);
                if (manufacturer) {
                    document.getElementById('manufacturerNameInput').value = manufacturer.name;
                    document.getElementById('manufacturerDescInput').value = manufacturer.description;
                }
            }
        }

        function renderCheckboxes() {
            const catContainer = document.getElementById('categoryCheckboxes');
            if (allCategories.length === 0) {
                catContainer.innerHTML = '<div class="text-gray-400 text-xs italic">Пусто</div>';
            } else {
                catContainer.innerHTML = allCategories.map(cat => `
                    <label class="flex items-center space-x-2 cursor-pointer group">
                        <input type="checkbox" name="productCategory" value="${cat.id}" id="cat-cb-${cat.id}" class="checkbox-custom rounded border-gray-300 w-4 h-4 cursor-pointer" onchange="handleCategoryCheckbox(this)">
                        <span class="text-gray-700 group-hover:text-st-purple transition-colors">${cat.name}</span>
                    </label>
                `).join('');
            }

            const mfgContainer = document.getElementById('manufacturerCheckboxes');
            if (allManufacturers.length === 0) {
                mfgContainer.innerHTML = '<div class="text-gray-400 text-xs italic">Пусто</div>';
            } else {
                mfgContainer.innerHTML = allManufacturers.map(mfg => `
                    <label class="flex items-center space-x-2 cursor-pointer group">
                        <input type="checkbox" name="productManufacturer" value="${mfg.id}" id="mfg-cb-${mfg.id}" class="checkbox-custom rounded border-gray-300 w-4 h-4 cursor-pointer" onchange="handleManufacturerCheckbox(this)">
                        <span class="text-gray-700 group-hover:text-st-purple transition-colors">${mfg.name}</span>
                    </label>
                `).join('');
            }

            handleProductTypeChange();
        }

        function renderDynamicFields(catId) {
            const section = document.getElementById('dynamicSection');
            const title = document.getElementById('dynamicTitle');
            const grid = document.getElementById('dynamicGrid');
            
            if (!catId) {
                section.classList.add('hidden');
                grid.innerHTML = '';
                return;
            }

            const category = allCategories.find(c => c.id == catId);
            if (!category) return;

            title.innerText = `Характеристики для: ${category.name}`;
            const schemaKey = categoryKeyByName[category.name];
            
            if (schemaKey === 'pc') {
                let html = '';
                
                // ДОДАНО ПОШУК ДЛЯ ОХОЛОДЖЕННЯ ТА КОРПУСУ
                const catMap = { 
                    'cpu': 'процесор', 
                    'gpu': 'відеокарт', 
                    'motherboard': 'материнськ', 
                    'ram': 'оперативна пам', 
                    'storage': 'накопичувач',
                    'ssd': 'ssd',
                    'hdd': 'hdd',
                    'psu': 'блок',
                    'cooler': 'охолодження',
                    'case': 'корпус'
                };

                specsSchema.pc.forEach(field => {
                    const searchWord = catMap[field.id];
                    let optionsHtml = `<option value="">Оберіть ${field.label}...</option>`;
                    
                    if (searchWord) {
                        let targetCat = null;
                        
                        // Спеціальна логіка для накопичувачів
                        if (field.id === 'storage') {
                            // Спочатку шукаємо SSD, потім HDD
                            targetCat = allCategories.find(c => 
                                c.name.toLowerCase().includes('ssd') && 
                                c.name.toLowerCase().includes('накопичувач')
                            );
                            if (!targetCat) {
                                targetCat = allCategories.find(c => 
                                    c.name.toLowerCase().includes('hdd') && 
                                    c.name.toLowerCase().includes('накопичувач')
                                );
                            }
                        } else {
                            targetCat = allCategories.find(c => c.name.toLowerCase().includes(searchWord));
                        }
                        
                        if (targetCat) {
                            const availableComponents = allProducts.filter(p => p.categoryId == targetCat.id);
                            availableComponents.forEach(p => {
                                let specsStr = '{}';
                                if (p.specs) {
                                    specsStr = typeof p.specs === 'string' ? p.specs : JSON.stringify(p.specs);
                                    specsStr = specsStr.replace(/"/g, '&quot;');
                                }
                                optionsHtml += `<option value="${p.id}" data-specs="${specsStr}">${p.name} (${p.price} ₴)</option>`;
                            });
                        }
                        
                        html += `
                        <div>
                            <label class="block text-xs font-semibold text-gray-500 mb-1 uppercase">${field.label}</label>
                            <select class="border border-gray-300 rounded p-2 text-sm w-full outline-none focus:border-st-purple bg-white" 
                                    id="spec_${field.id}" 
                                    onchange="checkPcCompatibility()">
                                ${optionsHtml}
                            </select>
                        </div>`;
                    } else {
                        html += `
