        function checkPcCompatibility() {
            const moboSelect = document.getElementById('spec_motherboard');
            const cpuSelect = document.getElementById('spec_cpu');
            const ramSelect = document.getElementById('spec_ram');
            const gpuSelect = document.getElementById('spec_gpu');
            const psuSelect = document.getElementById('spec_psu');

            // --- 1. ПЕРЕВІРКА СОКЕТУ ТА ОЗП ---
            let requiredSocket = null;
            let requiredRamType = null;

            if (moboSelect && moboSelect.value !== "") {
                const moboSpecs = parseSpecs(moboSelect.options[moboSelect.selectedIndex]);
                requiredSocket = moboSpecs['Сокет'] ? moboSpecs['Сокет'].toLowerCase().trim() : null;
                requiredRamType = moboSpecs["Тип пам'яті"] ? moboSpecs["Тип пам'яті"].toLowerCase().trim() : null;
            }

            // Перевірка Процесора
            if (cpuSelect) {
                Array.from(cpuSelect.options).forEach(opt => {
                    if (opt.value === "") return;

                    if (!requiredSocket) {
                        opt.disabled = false;
                        opt.text = opt.text.replace(' ❌ Не підходить сокет', '');
                        return;
                    }

                    const cpuSpecs = parseSpecs(opt);
                    const cpuSocket = cpuSpecs['Сокет'] ? cpuSpecs['Сокет'].toLowerCase().trim() : null;

                    if (cpuSocket && cpuSocket !== requiredSocket) {
                        opt.disabled = true;
                        if (!opt.text.includes('❌')) opt.text += ' ❌ Не підходить сокет';
                        if (cpuSelect.value === opt.value) cpuSelect.value = "";
                    } else {
                        opt.disabled = false;
                        opt.text = opt.text.replace(' ❌ Не підходить сокет', '');
                    }
                });
            }

            // Перевірка Оперативки
            if (ramSelect) {
                Array.from(ramSelect.options).forEach(opt => {
                    if (opt.value === "") return;
                    
                    if (!requiredRamType) {
                        opt.disabled = false;
                        opt.text = opt.text.replace(' ❌ Не підходить тип', '');
                        return;
                    }

                    const ramSpecs = parseSpecs(opt);
                    const ramType = ramSpecs["Тип пам'яті"] ? ramSpecs["Тип пам'яті"].toLowerCase().trim() : null;

                    if (ramType && !ramType.includes(requiredRamType) && !requiredRamType.includes(ramType)) {
                        opt.disabled = true;
                        if (!opt.text.includes('❌')) opt.text += ' ❌ Не підходить тип';
                        if (ramSelect.value === opt.value) ramSelect.value = "";
                    } else {
                        opt.disabled = false;
                        opt.text = opt.text.replace(' ❌ Не підходить тип', '');
                    }
                });
            }

            // --- 2. ПЕРЕВІРКА GPU vs PSU ---
            let selectedGpuTdp = 0;
            let selectedPsuPower = 0;

            if (gpuSelect && gpuSelect.value !== "") {
                const gpuSpecs = parseSpecs(gpuSelect.options[gpuSelect.selectedIndex]);
                selectedGpuTdp = parseInt(gpuSpecs['Енергоспоживання (Вт)']) || 0;
            }

            if (psuSelect && psuSelect.value !== "") {
                const psuSpecs = parseSpecs(psuSelect.options[psuSelect.selectedIndex]);
                selectedPsuPower = parseInt(psuSpecs['Потужність (Вт)']) || 0;
            }

            // Якщо вибрано GPU - блокуємо заслабкі блоки живлення
            if (psuSelect) {
                Array.from(psuSelect.options).forEach(opt => {
                    if (opt.value === "") return;
                    
                    if (selectedGpuTdp > 0) {
                        const psuSpecs = parseSpecs(opt);
                        // Запобіжник: якщо у БЖ не вказана потужність, ставимо 9999 щоб не блокувати його помилково
                        const psuPower = parseInt(psuSpecs['Потужність (Вт)']) || 9999; 
                        
                        if (selectedGpuTdp > psuPower) {
                            opt.disabled = true;
                            if (!opt.text.includes('❌ Заслабкий')) opt.text += ' ❌ Заслабкий для відеокарти';
                            if (psuSelect.value === opt.value) psuSelect.value = "";
                        } else {
                            opt.disabled = false;
                            opt.text = opt.text.replace(' ❌ Заслабкий для відеокарти', '');
                        }
                    } else {
                        opt.disabled = false;
                        opt.text = opt.text.replace(' ❌ Заслабкий для відеокарти', '');
                    }
                });
            }

            // Якщо вибрано PSU - блокуємо занадто потужні відеокарти
            if (gpuSelect) {
                Array.from(gpuSelect.options).forEach(opt => {
                    if (opt.value === "") return;
                    
                    if (selectedPsuPower > 0) {
                        const gpuSpecs = parseSpecs(opt);
                        const gpuTdp = parseInt(gpuSpecs['Енергоспоживання (Вт)']) || 0;
                        
                        if (gpuTdp > selectedPsuPower) {
                            opt.disabled = true;
                            if (!opt.text.includes('❌ Не вистачає')) opt.text += ' ❌ Не вистачає БЖ';
                            if (gpuSelect.value === opt.value) gpuSelect.value = "";
                        } else {
                            opt.disabled = false;
                            opt.text = opt.text.replace(' ❌ Не вистачає БЖ', '');
                        }
                    } else {
                        opt.disabled = false;
                        opt.text = opt.text.replace(' ❌ Не вистачає БЖ', '');
                    }
                });
            }
        }

