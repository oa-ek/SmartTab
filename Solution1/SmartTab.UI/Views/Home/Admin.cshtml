        function deleteProduct(id) {
            if(confirm('Видалити цей товар?')) {
                fetch('/api/products/' + id, { method: 'DELETE' })
                .then(r => r.ok ? loadData() : alert('Помилка'))
                .catch(() => alert('Помилка видалення'));
            }
        }

        function editProduct(id) {
            const product = allProducts.find(p => p.id == id);
            if (!product) return;

            resetForm(); 

            document.getElementById('productId').value = product.id;
            document.getElementById('productType').value = product.productType || 0;
            
            handleProductTypeChange();

            document.getElementById('name').value = product.name || '';
            document.getElementById('price').value = product.price || '';
            document.getElementById('stockCount').value = product.stockCount !== undefined && product.stockCount !== null ? product.stockCount : '';
            document.getElementById('initialQuantity').value = product.initialQuantity !== undefined && product.initialQuantity !== null ? product.initialQuantity : '';
            
            if (product.categoryId) {
                document.querySelectorAll('input[name="productCategory"]').forEach(cb => {
                    if (cb.value == product.categoryId) {
                        cb.checked = true;
                    }
                });
                renderDynamicFields(product.categoryId);
            }

            if (product.manufacturerId) {
                document.querySelectorAll('input[name="productManufacturer"]').forEach(cb => {
                    if (cb.value == product.manufacturerId) {
                        cb.checked = true;
                    }
                });
            }

            if (product.imageUrl) {
                document.getElementById('imagePreview').src = product.imageUrl;
                document.getElementById('imagePreview').classList.remove('hidden');
                document.getElementById('uploadPlaceholder').classList.add('hidden');
            }
            
            const catInfo = allCategories.find(c => c.id == product.categoryId);
            if (catInfo) {
                const schemaKey = categoryKeyByName[catInfo.name];
                if (schemaKey && specsSchema[schemaKey] && product.specs) {
                    const pSpecs = parseSpecs({ dataset: { specs: typeof product.specs === 'string' ? product.specs : JSON.stringify(product.specs) } });
                    
                    specsSchema[schemaKey].forEach(field => {
                        const el = document.getElementById(`spec_${field.id}`);
                        if (el) {
                            el.value = pSpecs[field.label] || '';
                        }
                    });
                    
                    if (schemaKey === 'pc') {
                        checkPcCompatibility();
                    }
                }
            }

            document.getElementById('form-title').innerText = 'Редагувати товар';
            document.getElementById('submitBtn').innerText = 'Зберегти зміни';
            document.getElementById('submitBtn').onclick = updateProduct;
            document.getElementById('cancelBtn').classList.remove('hidden');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

