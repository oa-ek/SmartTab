@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SmartTab Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --st-purple: #6f00ff;
            --st-purple-hover: #5b00d6;
        }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; background-color: #f8f9fa; }
        .bg-st-purple { background-color: var(--st-purple); }
        .hover\:bg-st-purple-hover:hover { background-color: var(--st-purple-hover); }
        .text-st-purple { color: var(--st-purple); }
        .border-st-purple { border-color: var(--st-purple); }
        
        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #f1f1f1; border-radius: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #c1c1c1; border-radius: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #a8a8a8; }
        
        input:focus, select:focus, textarea:focus { 
            outline: none; 
            border-color: var(--st-purple); 
            box-shadow: 0 0 0 2px rgba(111, 0, 255, 0.1); 
        }

        .checkbox-custom:checked {
            background-color: var(--st-purple);
            border-color: var(--st-purple);
        }
    </style>
</head>
<body class="text-gray-800">
    <div class="min-h-screen flex flex-col">
        <header class="bg-black border-b border-gray-900 sticky top-0 z-50 shadow-md text-white">
            <div class="max-w-[1400px] mx-auto px-4 h-[70px] flex items-center justify-between gap-4">
                <div class="flex items-center gap-4 shrink-0">
                    <button class="text-2xl hover:text-st-purple transition-colors"><i class="fas fa-bars"></i></button>
                    <div class="flex items-center text-st-purple text-2xl font-bold tracking-tight cursor-pointer">
                        <i class="fas fa-layer-group mr-2 text-2xl"></i>
                        <span>SmartTab <span class="text-white font-black">Admin</span></span>
                    </div>
                </div>

                <div class="flex-1 max-w-xl mx-8 relative hidden md:block flex items-center">
                    <input type="text" id="searchInput" placeholder="Я шукаю..." 
                           class="w-full py-2.5 px-4 pr-[100px] rounded border-none text-sm focus:ring-2 focus:ring-st-purple text-black bg-white outline-none" 
                           onkeyup="filterProducts()">
                    <button class="absolute right-0 top-0 h-full px-6 bg-st-purple hover:bg-st-purple-hover transition-colors text-white text-sm font-medium rounded-r">
                        Знайти
                    </button>
                </div>
                
                <div class="w-[24px]"></div>
            </div>
        </header>

        <main class="max-w-[1400px] mx-auto w-full px-4 py-8">
            <div class="bg-white p-6 rounded shadow-sm mb-8 border border-gray-100">
                <h2 class="text-xl font-bold mb-6 text-gray-900 border-b-2 border-st-purple inline-block pb-1" id="form-title">
                    Додати товар
                </h2>
                
                <form id="product-form">
                    <input type="hidden" id="productId" value="">
                    
                    <div class="flex flex-col md:flex-row gap-6">
                        <div class="w-full md:w-[200px] shrink-0">
                            <div class="border-2 border-dashed border-gray-300 rounded w-full h-[200px] flex flex-col items-center justify-center text-gray-500 hover:border-st-purple cursor-pointer relative bg-gray-50 transition-colors group">
                                <input id="imageInput" type="file" class="absolute inset-0 opacity-0 cursor-pointer z-10" accept="image/*" onchange="previewImage(this)">
                                <div id="uploadPlaceholder" class="text-center group-hover:text-st-purple transition-colors">
                                    <span class="block text-sm font-medium">Додати<br>фото</span>
                                </div>
                                <img id="imagePreview" src="" class="hidden w-full h-full object-contain p-2">
                            </div>
                        </div>

                        <div class="flex-1 flex flex-col gap-4">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <select id="productType" class="border border-gray-300 rounded p-2.5 text-sm w-full bg-white text-gray-700 transition-colors">
                                    <option value="0">Компонент (Component)</option>
                                    <option value="1">Готовий ПК</option>
                                </select>
                                <input type="number" id="price" step="0.01" min="0" class="border border-gray-300 rounded p-2.5 text-sm w-full" placeholder="Ціна (₴)">
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <input type="text" id="name" class="border border-gray-300 rounded p-2.5 text-sm w-full" placeholder="Назва товару">
                                <input type="number" id="stockCount" min="0" class="border border-gray-300 rounded p-2.5 text-sm w-full" placeholder="Кількість на складі">
                            </div>

                            <input type="number" id="initialQuantity" min="0" class="border border-gray-300 rounded p-2.5 text-sm w-full" placeholder="Початкова кількість (для генерації серійних номерів)">
                            
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-2">
                                <div class="border border-gray-200 rounded p-3 bg-gray-50/50">
                                    <label class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-2 block">Категорія</label>
                                    <div id="categoryCheckboxes" class="max-h-32 overflow-y-auto space-y-2 custom-scrollbar pr-2">
                                    </div>
                                </div>
                                <div class="border border-gray-200 rounded p-3 bg-gray-50/50">
                                    <label class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-2 block">Виробник</label>
                                    <div id="manufacturerCheckboxes" class="max-h-32 overflow-y-auto space-y-2 custom-scrollbar pr-2">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="dynamicSection" class="hidden mt-8 pt-6 border-t border-dashed border-gray-200">
                        <h3 id="dynamicTitle" class="font-bold text-gray-900 mb-4 text-sm">Характеристики:</h3>
                        <div id="dynamicGrid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4 text-sm text-gray-600">
                        </div>
                    </div>

                    <div class="mt-8 flex gap-3">
                        <button type="button" id="submitBtn" onclick="addProduct()" class="flex-1 bg-st-purple hover:bg-st-purple-hover text-white font-medium py-2.5 px-6 rounded transition-colors text-sm">
                            Додати до каталогу
                        </button>
                        <button type="button" id="cancelBtn" onclick="resetForm()" class="hidden bg-gray-200 hover:bg-gray-300 text-gray-700 font-medium py-2.5 px-6 rounded transition-colors text-sm">
                            Скасувати
                        </button>
                    </div>
                </form>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-8">
                <div class="bg-white rounded shadow-sm border border-gray-100 p-5">
                    <h2 class="text-sm font-bold mb-4 text-gray-900 flex items-center">
                        <i class="fas fa-tags text-st-purple mr-2"></i> Керування категоріями
                    </h2>
                    <form id="category-form" class="space-y-3">
                        <input type="hidden" id="editCategoryId" value="">
                        <input type="text" id="categoryNameInput" class="w-full border border-gray-300 rounded p-2 text-sm" placeholder="Назва категорії">
                        <div class="flex gap-2">
                            <button type="button" id="categorySubmitBtn" onclick="addCategory()" class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-800 font-medium py-2 rounded transition-colors text-sm">
                                Зберегти
                            </button>
                            <button type="button" id="categoryCancelBtn" onclick="resetCategoryForm()" class="hidden bg-gray-100 hover:bg-gray-200 text-gray-600 px-3 rounded text-sm">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    </form>
                    <div id="categories-list" class="mt-4 space-y-1 max-h-[200px] overflow-y-auto custom-scrollbar pr-2 text-sm"></div>
                </div>

                <div class="bg-white rounded shadow-sm border border-gray-100 p-5 lg:col-span-2">
                    <h2 class="text-sm font-bold mb-4 text-gray-900 flex items-center">
                        <i class="fas fa-industry text-st-purple mr-2"></i> Керування виробниками
                    </h2>
                    <div class="flex flex-col md:flex-row gap-6">
                        <form id="manufacturer-form" class="flex-1 space-y-3">
                            <input type="hidden" id="editManufacturerId" value="">
                            <input type="text" id="manufacturerNameInput" class="w-full border border-gray-300 rounded p-2 text-sm" placeholder="Назва виробника">
                            <textarea id="manufacturerDescInput" rows="2" class="w-full border border-gray-300 rounded p-2 text-sm" placeholder="Опис виробника (необов'язково)"></textarea>
                            <div class="flex gap-2">
                                <button type="button" id="manufacturerSubmitBtn" onclick="addManufacturer()" class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-800 font-medium py-2 rounded transition-colors text-sm">
                                    Зберегти виробника
                                </button>
                                <button type="button" id="manufacturerCancelBtn" onclick="resetManufacturerForm()" class="hidden bg-gray-100 hover:bg-gray-200 text-gray-600 px-3 rounded text-sm">
                                    <i class="fas fa-times"></i>
                                </button>
                            </div>
                        </form>
                        <div class="flex-1">
                            <div id="manufacturers-list" class="space-y-1 max-h-[200px] overflow-y-auto custom-scrollbar pr-2 text-sm"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded shadow-sm border border-gray-100 p-6">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-xl font-bold text-gray-900">Всі товари <span id="product-count-label" class="text-gray-400 font-normal ml-2 text-sm"></span></h2>
                </div>
                
                <div id="products-grid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-6">
                </div>
            </div>
        </main>
    </div>

    <script>
        const categoryMapping = {
            '1': { label: 'Готовий ПК', key: 'pc' },
            '2': { label: 'Процесор', key: 'cpu' },
            '3': { label: 'Відеокарта', key: 'gpu' },
            '4': { label: 'Материнська плата', key: 'motherboard' },
            '5': { label: 'ОЗП', key: 'ram' },
            '6': { label: 'SSD', key: 'ssd' },
            '7': { label: 'HDD', key: 'hdd' },
            '8': { label: 'Блок живлення', key: 'psu' }
        };

        const specsSchema = {
            pc: [
                { id: 'cpu', label: 'Процесор' }, { id: 'gpu', label: 'Відеокарта' },
                { id: 'motherboard', label: 'Материнська плата' }, { id: 'cooler', label: 'Охолодження' },
                { id: 'ram', label: 'ОЗП' }, { id: 'storage', label: 'Накопичувач' },
                { id: 'psu', label: 'Блок живлення' }, { id: 'case', label: 'Корпус' }
            ],
            cpu: [
                { id: 'cores', label: 'Кількість ядер' }, { id: 'threads', label: 'Кількість потоків' },
                { id: 'socket', label: 'Сокет' }, { id: 'tdp', label: 'TDP (Вт)' },
                { id: 'frequency', label: 'Частота (ГГц)' }
            ],
            gpu: [
                { id: 'vram', label: "Об'єм пам'яті (ГБ)" }, { id: 'memoryType', label: "Тип пам'яті" },
                { id: 'tdp', label: 'Енергоспоживання (Вт)' }
            ],
            motherboard: [
                { id: 'socket', label: 'Сокет' }, { id: 'chipset', label: 'Чипсет' },
                { id: 'formFactor', label: 'Форм-фактор' }
            ],
            ram: [
                { id: 'capacity', label: "Об'єм (ГБ)" }, { id: 'type', label: "Тип (DDR4/DDR5)" },
                { id: 'frequency', label: 'Частота (МГц)' }, { id: 'latency', label: 'Таймінги (CL)' }
            ],
            ssd: [
                { id: 'capacity', label: "Об'єм (ГБ/ТБ)" }, { id: 'formFactor', label: 'Форм-фактор (2.5"/M.2)' },
                { id: 'interface', label: 'Інтерфейс (SATA/NVMe)' }, { id: 'readSpeed', label: 'Швидкість читання (МБ/с)' }
            ],
            hdd: [
                { id: 'capacity', label: "Об'єм (ГБ/ТБ)" }, { id: 'rpm', label: 'Швидкість шпинделя (об/хв)' },
                { id: 'buffer', label: 'Буфер (МБ)' }, { id: 'interface', label: 'Інтерфейс' }
            ],
            psu: [
                { id: 'power', label: 'Потужність (Вт)' }, { id: 'certification', label: 'Сертифікат (80+)' },
                { id: 'formFactor', label: 'Форм-фактор (ATX/SFX)' }
            ]
        };

        let allProducts = [];
        let allCategories = [];
        let allManufacturers = [];

        document.addEventListener('DOMContentLoaded', loadData);

        function previewImage(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    document.getElementById('imagePreview').src = e.target.result;
                    document.getElementById('imagePreview').classList.remove('hidden');
                    document.getElementById('uploadPlaceholder').classList.add('hidden');
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        function handleCategoryCheckbox(checkbox) {
            document.querySelectorAll('input[name="productCategory"]').forEach(cb => {
                if (cb !== checkbox) cb.checked = false;
            });
            
            const catId = checkbox.checked ? checkbox.value : '';
            const productTypeSelect = document.getElementById('productType');
            
            if (catId) {
                const catInfo = categoryMapping[catId];
                const selectedCat = allCategories.find(c => c.id == catId);
                const isPc = (catInfo && catInfo.key === 'pc') || (selectedCat && selectedCat.name.toLowerCase().includes('готовий пк'));
                
                productTypeSelect.value = isPc ? '1' : '0';
                productTypeSelect.setAttribute('disabled', 'true');
                productTypeSelect.classList.add('bg-gray-100', 'cursor-not-allowed', 'opacity-70');
            } else {
                productTypeSelect.value = '0';
                productTypeSelect.removeAttribute('disabled');
                productTypeSelect.classList.remove('bg-gray-100', 'cursor-not-allowed', 'opacity-70');
            }

            renderDynamicFields(catId);
        }

        function handleManufacturerCheckbox(checkbox) {
            document.querySelectorAll('input[name="productManufacturer"]').forEach(cb => {
                if (cb !== checkbox) cb.checked = false;
            });
        }

        function renderCheckboxes() {
            const catContainer = document.getElementById('categoryCheckboxes');
            if (allCategories.length === 0) {
                catContainer.innerHTML = '<div class="text-gray-400 text-xs italic">Пусто</div>';
            } else {
                catContainer.innerHTML = allCategories.map(cat => `
                    <label class="flex items-center space-x-2 cursor-pointer group py-0.5">
                        <input type="checkbox" name="productCategory" value="${cat.id}" id="cat-cb-${cat.id}" class="checkbox-custom rounded border-gray-300 w-4 h-4 cursor-pointer" onchange="handleCategoryCheckbox(this)">
                        <span class="text-gray-700 group-hover:text-st-purple transition-colors text-sm">${cat.name}</span>
                    </label>
                `).join('');
            }

            const mfgContainer = document.getElementById('manufacturerCheckboxes');
            if (allManufacturers.length === 0) {
                mfgContainer.innerHTML = '<div class="text-gray-400 text-xs italic">Пусто</div>';
            } else {
                mfgContainer.innerHTML = allManufacturers.map(mfg => `
                    <label class="flex items-center space-x-2 cursor-pointer group py-0.5">
                        <input type="checkbox" name="productManufacturer" value="${mfg.id}" id="mfg-cb-${mfg.id}" class="checkbox-custom rounded border-gray-300 w-4 h-4 cursor-pointer" onchange="handleManufacturerCheckbox(this)">
                        <span class="text-gray-700 group-hover:text-st-purple transition-colors text-sm">${mfg.name}</span>
                    </label>
                `).join('');
            }
        }

        function renderDynamicFields(catId) {
            const section = document.getElementById('dynamicSection');
            const title = document.getElementById('dynamicTitle');
            const grid = document.getElementById('dynamicGrid');
            
            if (!catId) {
                section.classList.add('hidden');
                grid.innerHTML = '';
                return;
            }

            const catInfo = categoryMapping[catId];
            if (!catInfo || !specsSchema[catInfo.key]) {
                section.classList.add('hidden');
                grid.innerHTML = '';
                return;
            }

            title.innerText = `Характеристики для ${catInfo.label}:`;
            
            let html = '';
            specsSchema[catInfo.key].forEach(field => {
                html += `<input type="text" class="border border-gray-300 rounded p-2 text-sm w-full outline-none focus:border-st-purple" id="spec_${field.id}" placeholder="${field.label}">`;
            });
            
            grid.innerHTML = html;
            section.classList.remove('hidden');
        }

        function loadData() {
            Promise.all([
                fetch('/api/categories').then(res => res.json()).catch(() => []),
                fetch('/api/manufacturers').then(res => res.json()).catch(() => []),
                fetch('/api/products').then(res => res.json()).catch(() => [])
            ]).then(([categories, manufacturers, products]) => {
                allCategories = categories.map(c => ({...c, productCount: products.filter(p => p.categoryId == c.id).length}));
                allManufacturers = manufacturers.map(m => ({...m, productCount: products.filter(p => p.manufacturerId == m.id).length}));
                allProducts = products;

                renderCheckboxes();
                renderCategoryList();
                renderManufacturerList();
                renderProducts(allProducts);
            });
        }

        function renderProducts(products) {
            const grid = document.getElementById('products-grid');
            document.getElementById('product-count-label').innerText = `${products.length} од.`;

            if (products.length === 0) {
                grid.innerHTML = '<div class="col-span-full py-10 text-center text-gray-400">Товарів не знайдено</div>';
                return;
            }

            let html = '';
            products.forEach(p => {
                let specsText = 'Не вказано';
                if (p.specs) {
                    try {
                        const parsed = typeof p.specs === 'string' ? JSON.parse(p.specs) : p.specs;
                        if (Array.isArray(parsed)) {
                            const vals = parsed.map(s => s.value).filter(Boolean);
                            if (vals.length > 0) specsText = vals.join(' / ');
                        } else if (typeof parsed === 'object') {
                            const vals = Object.values(parsed).filter(Boolean);
                            if (vals.length > 0) specsText = vals.join(' / ');
                        }
                    } catch(e) {}
                }

                const imageHtml = p.imageUrl 
                    ? `<img src="${p.imageUrl}" alt="${p.name}" class="h-full w-full object-contain p-2">`
                    : `<div class="h-full w-full flex items-center justify-center bg-gray-50"><i class="fas fa-image text-gray-300 text-4xl"></i></div>`;
                
                const mfgName = allManufacturers.find(m => m.id == p.manufacturerId)?.name || 'Не вказано';
                const currentStock = p.stockCount !== undefined && p.stockCount !== null ? p.stockCount : 0;

                html += `
                <div class="border border-gray-200 rounded-lg p-4 flex flex-col hover:shadow-md transition-shadow bg-white relative group">
                    <div class="absolute top-2 right-2 flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity z-10">
                        <button onclick="editProduct(${p.id})" class="bg-gray-50 hover:bg-gray-100 text-gray-500 w-8 h-8 rounded flex items-center justify-center transition-colors">
                            <i class="fas fa-pen text-xs"></i>
                        </button>
                        <button onclick="deleteProduct(${p.id})" class="bg-gray-50 hover:bg-gray-100 text-gray-500 w-8 h-8 rounded flex items-center justify-center transition-colors">
                            <i class="fas fa-trash text-xs"></i>
                        </button>
                    </div>

                    <div class="h-48 mb-4 rounded overflow-hidden flex items-center justify-center">
                        ${imageHtml}
                    </div>

                    <div class="text-[13px] text-st-purple font-medium mb-1">${mfgName}</div>
                    
                    <div class="font-medium text-gray-900 text-base mb-2 leading-snug">
                        ${p.name}
                    </div>

                    <div class="text-[13px] text-gray-600 mb-4 leading-relaxed">
                        ${specsText}
                    </div>

                    <div class="mt-auto pt-3 border-t border-gray-100">
                        <div class="text-2xl font-bold text-[#f84147] leading-none mb-2">${p.price} ₴</div>
                        <div class="text-[13px] text-gray-500">Залишок: <span class="font-bold text-gray-900">${currentStock}</span> шт</div>
                    </div>
                </div>`;
            });
            grid.innerHTML = html;
        }

        function filterProducts() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase().trim();
            const filtered = allProducts.filter(p => p.name.toLowerCase().includes(searchTerm));
            renderProducts(filtered);
        }

        function getSelectedId(name) {
            const el = document.querySelector(`input[name="${name}"]:checked`);
            return el ? el.value : '';
        }

        function validateProductForm() {
            const name = document.getElementById('name').value.trim();
            const price = parseFloat(document.getElementById('price').value);
            const categoryId = getSelectedId('productCategory');

            if (!name) { alert('Введіть назву товару'); return false; }
            if (!price || price <= 0) { alert('Введіть коректну ціну'); return false; }
            if (!categoryId) { alert('Виберіть категорію'); return false; }
            return true;
        }

        async function addProduct() {
            if (!validateProductForm()) return;

            const btn = document.getElementById('submitBtn');
            btn.disabled = true; btn.innerText = 'Завантаження...';

            const catId = getSelectedId('productCategory');
            const mfgId = getSelectedId('productManufacturer');
            const stockVal = document.getElementById('stockCount').value;
            const initVal = document.getElementById('initialQuantity').value;
            
            const formData = new FormData();
            formData.append('productType', document.getElementById('productType').value || "0");
            formData.append('categoryId', catId || "0");
            formData.append('manufacturerId', mfgId || "0");
            formData.append('name', document.getElementById('name').value.trim());
            formData.append('price', document.getElementById('price').value || "0");
            formData.append('stockCount', stockVal || "0");
            formData.append('initialQuantity', initVal || "0");

            let specs = {};
            const catInfo = categoryMapping[catId];
            if (catInfo && specsSchema[catInfo.key]) {
                specsSchema[catInfo.key].forEach(field => {
                    const el = document.getElementById(`spec_${field.id}`);
                    if (el && el.value.trim()) specs[field.label] = el.value.trim();
                });
            }
            formData.append('specsJson', JSON.stringify(specs));

            const img = document.getElementById('imageInput').files[0];
            if (img) formData.append('image', img);

            try {
                const response = await fetch('/api/products', { method: 'POST', body: formData });
                if (response.ok) { resetForm(); loadData(); } 
                else { alert('Помилка: ' + await response.text()); }
            } catch (err) { alert('Сталася мережева помилка'); }
            finally { btn.disabled = false; btn.innerText = 'Додати до каталогу'; }
        }

        async function updateProduct() {
            if (!validateProductForm()) return;

            const btn = document.getElementById('submitBtn');
            btn.disabled = true; btn.innerText = 'Оновлення...';

            const id = document.getElementById('productId').value;
            const catId = getSelectedId('productCategory');
            const mfgId = getSelectedId('productManufacturer');
            const stockVal = document.getElementById('stockCount').value;
            const initVal = document.getElementById('initialQuantity').value;
            
            const formData = new FormData();
            formData.append('id', id);
            formData.append('productType', document.getElementById('productType').value || "0");
            formData.append('categoryId', catId || "0");
            formData.append('manufacturerId', mfgId || "0");
            formData.append('name', document.getElementById('name').value.trim());
            formData.append('price', document.getElementById('price').value || "0");
            formData.append('stockCount', stockVal || "0");
            formData.append('initialQuantity', initVal || "0");

            let specs = {};
            const catInfo = categoryMapping[catId];
            if (catInfo && specsSchema[catInfo.key]) {
                specsSchema[catInfo.key].forEach(field => {
                    const el = document.getElementById(`spec_${field.id}`);
                    if (el && el.value.trim()) specs[field.label] = el.value.trim();
                });
            }
            formData.append('specsJson', JSON.stringify(specs));

            const img = document.getElementById('imageInput').files[0];
            if (img) formData.append('image', img);

            try {
                const response = await fetch('/api/products/' + id, { method: 'PUT', body: formData });
                if (response.ok) { resetForm(); loadData(); } 
                else { alert('Помилка: ' + await response.text()); }
            } catch (err) { alert('Сталася мережева помилка'); }
            finally { btn.disabled = false; btn.innerText = 'Додати до каталогу'; }
        }

        function deleteProduct(id) {
            if(confirm('Видалити цей товар?')) {
                fetch('/api/products/' + id, { method: 'DELETE' })
                .then(r => r.ok ? loadData() : alert('Помилка'))
                .catch(() => alert('Помилка видалення'));
            }
        }

        function editProduct(id) {
            const product = allProducts.find(p => p.id == id);
            if (!product) return;

            resetForm(); 

            document.getElementById('productId').value = product.id;
            document.getElementById('name').value = product.name || '';
            document.getElementById('price').value = product.price || '';
            document.getElementById('stockCount').value = product.stockCount !== undefined && product.stockCount !== null ? product.stockCount : 0;
            document.getElementById('initialQuantity').value = 0;
            
            const productTypeSelect = document.getElementById('productType');
            if (product.productType !== undefined) {
                productTypeSelect.value = product.productType;
                productTypeSelect.setAttribute('disabled', 'true');
                productTypeSelect.classList.add('bg-gray-100', 'cursor-not-allowed', 'opacity-70');
            }
            
            if (product.categoryId) {
                document.querySelectorAll('input[name="productCategory"]').forEach(cb => {
                    if (cb.value == product.categoryId) {
                        cb.checked = true;
                    }
                });
                renderDynamicFields(product.categoryId);
            }

            if (product.manufacturerId) {
                document.querySelectorAll('input[name="productManufacturer"]').forEach(cb => {
                    if (cb.value == product.manufacturerId) {
                        cb.checked = true;
                    }
                });
            }

            if (product.imageUrl) {
                document.getElementById('imagePreview').src = product.imageUrl;
                document.getElementById('imagePreview').classList.remove('hidden');
                document.getElementById('uploadPlaceholder').classList.add('hidden');
            }
            
            const catInfo = categoryMapping[product.categoryId];
            if (catInfo && specsSchema[catInfo.key] && product.specs) {
                let parsedSpecs = {};
                try {
                    const parsed = typeof product.specs === 'string' ? JSON.parse(product.specs) : product.specs;
                    if (Array.isArray(parsed)) {
                        parsed.forEach(s => parsedSpecs[s.name] = s.value);
                    } else if (typeof parsed === 'object') {
                        parsedSpecs = parsed;
                    }
                } catch(e) {}

                specsSchema[catInfo.key].forEach(field => {
                    const el = document.getElementById(`spec_${field.id}`);
                    if (el) {
                        el.value = parsedSpecs[field.label] || '';
                    }
                });
            }

            document.getElementById('form-title').innerText = 'Редагувати товар';
            document.getElementById('submitBtn').innerText = 'Зберегти зміни';
            document.getElementById('submitBtn').onclick = updateProduct;
            document.getElementById('cancelBtn').classList.remove('hidden');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function resetForm() {
            document.getElementById('product-form').reset();
            document.getElementById('productId').value = '';
            document.getElementById('imagePreview').classList.add('hidden');
            document.getElementById('uploadPlaceholder').classList.remove('hidden');
            document.getElementById('dynamicSection').classList.add('hidden');
            document.getElementById('dynamicGrid').innerHTML = '';
            
            const productTypeSelect = document.getElementById('productType');
            productTypeSelect.removeAttribute('disabled');
            productTypeSelect.classList.remove('bg-gray-100', 'cursor-not-allowed', 'opacity-70');
            productTypeSelect.value = '0';
            
            document.querySelectorAll('input[name="productCategory"]').forEach(cb => cb.checked = false);
            document.querySelectorAll('input[name="productManufacturer"]').forEach(cb => cb.checked = false);

            document.getElementById('form-title').innerText = 'Додати товар';
            document.getElementById('submitBtn').innerText = 'Додати до каталогу';
            document.getElementById('submitBtn').onclick = addProduct;
            document.getElementById('cancelBtn').classList.add('hidden');
        }

        function renderCategoryList() {
            const list = document.getElementById('categories-list');
            if(allCategories.length === 0) { list.innerHTML = '<div class="text-gray-400 italic">Пусто</div>'; return; }
            list.innerHTML = allCategories.map(cat => `
                <div class="flex justify-between items-center py-1.5 border-b border-gray-50 group">
                    <div><span class="font-medium text-gray-700">${cat.name}</span> <span class="text-gray-400 text-xs ml-1">(${cat.productCount})</span></div>
                    <div class="opacity-0 group-hover:opacity-100 flex gap-1">
                        <button onclick="editCategory(${cat.id})" class="text-gray-400 hover:text-st-purple"><i class="fas fa-pen text-xs"></i></button>
                        <button onclick="deleteCategory(${cat.id})" class="text-gray-400 hover:text-red-500 ml-1"><i class="fas fa-trash text-xs"></i></button>
                    </div>
                </div>
            `).join('');
        }

        async function addCategory() {
            const name = document.getElementById('categoryNameInput').value.trim();
            if(!name) return;
            const fd = new FormData(); fd.append('name', name);
            try {
                await fetch('/api/categories', {method: 'POST', body: fd});
                resetCategoryForm(); loadData();
            } catch (err) { console.error(err); }
        }

        function editCategory(id) {
            const cat = allCategories.find(c => c.id == id);
            if(!cat) return;
            document.getElementById('editCategoryId').value = cat.id;
            document.getElementById('categoryNameInput').value = cat.name;
            document.getElementById('categorySubmitBtn').innerText = 'Оновити';
            document.getElementById('categorySubmitBtn').onclick = updateCategory;
            document.getElementById('categoryCancelBtn').classList.remove('hidden');
        }

        async function updateCategory() {
            const id = document.getElementById('editCategoryId').value;
            const name = document.getElementById('categoryNameInput').value.trim();
            if(!name) return;
            const fd = new FormData(); fd.append('name', name);
            try {
                await fetch('/api/categories/'+id, {method: 'PUT', body: fd});
                resetCategoryForm(); loadData();
            } catch (err) { console.error(err); }
        }

        function deleteCategory(id) {
            const cat = allCategories.find(c => c.id == id);
            if(cat && cat.productCount > 0) { alert('Неможливо видалити, є товари.'); return; }
            if(confirm('Видалити?')) fetch('/api/categories/'+id, {method:'DELETE'}).then(()=>loadData());
        }

        function resetCategoryForm() {
            document.getElementById('category-form').reset();
            document.getElementById('editCategoryId').value = '';
            document.getElementById('categorySubmitBtn').innerText = 'Зберегти';
            document.getElementById('categorySubmitBtn').onclick = addCategory;
            document.getElementById('categoryCancelBtn').classList.add('hidden');
        }

        function renderManufacturerList() {
            const list = document.getElementById('manufacturers-list');
            if(allManufacturers.length === 0) { list.innerHTML = '<div class="text-gray-400 italic">Пусто</div>'; return; }
            list.innerHTML = allManufacturers.map(mfg => `
                <div class="flex justify-between items-center py-1.5 border-b border-gray-50 group">
                    <div>
                        <div class="font-medium text-gray-700">${mfg.name} <span class="text-gray-400 text-xs ml-1">(${mfg.productCount})</span></div>
                    </div>
                    <div class="opacity-0 group-hover:opacity-100 flex gap-1">
                        <button onclick="editManufacturer(${mfg.id})" class="text-gray-400 hover:text-st-purple"><i class="fas fa-pen text-xs"></i></button>
                        <button onclick="deleteManufacturer(${mfg.id})" class="text-gray-400 hover:text-red-500 ml-1"><i class="fas fa-trash text-xs"></i></button>
                    </div>
                </div>
            `).join('');
        }

        async function addManufacturer() {
            const name = document.getElementById('manufacturerNameInput').value.trim();
            if(!name) return;
            const fd = new FormData(); 
            fd.append('name', name);
            fd.append('description', document.getElementById('manufacturerDescInput').value.trim());
            try {
                await fetch('/api/manufacturers', {method: 'POST', body: fd});
                resetManufacturerForm(); loadData();
            } catch (err) { console.error(err); }
        }

        function editManufacturer(id) {
            const mfg = allManufacturers.find(m => m.id == id);
            if(!mfg) return;
            document.getElementById('editManufacturerId').value = mfg.id;
            document.getElementById('manufacturerNameInput').value = mfg.name;
            document.getElementById('manufacturerDescInput').value = mfg.description || '';
            document.getElementById('manufacturerSubmitBtn').innerText = 'Оновити';
            document.getElementById('manufacturerSubmitBtn').onclick = updateManufacturer;
            document.getElementById('manufacturerCancelBtn').classList.remove('hidden');
        }

        async function updateManufacturer() {
            const id = document.getElementById('editManufacturerId').value;
            const name = document.getElementById('manufacturerNameInput').value.trim();
            if(!name) return;
            const fd = new FormData(); 
            fd.append('name', name);
            fd.append('description', document.getElementById('manufacturerDescInput').value.trim());
            try {
                await fetch('/api/manufacturers/'+id, {method: 'PUT', body: fd});
                resetManufacturerForm(); loadData();
            } catch (err) { console.error(err); }
        }

        function deleteManufacturer(id) {
            const mfg = allManufacturers.find(m => m.id == id);
            if(mfg && mfg.productCount > 0) { alert('Неможливо видалити, є товари.'); return; }
            if(confirm('Видалити?')) fetch('/api/manufacturers/'+id, {method:'DELETE'}).then(()=>loadData());
        }

        function resetManufacturerForm() {
            document.getElementById('manufacturer-form').reset();
            document.getElementById('editManufacturerId').value = '';
            document.getElementById('manufacturerSubmitBtn').innerText = 'Зберегти виробника';
            document.getElementById('manufacturerSubmitBtn').onclick = addManufacturer;
            document.getElementById('manufacturerCancelBtn').classList.add('hidden');
        }
    </script>
</body>
</html>