@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SmartTab Store</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --st-purple: #6f00ff;
            --st-purple-hover: #5b00d6;
        }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; background-color: #f8f9fa; }
        .bg-st-purple { background-color: var(--st-purple); }
        .hover\:bg-st-purple-hover:hover { background-color: var(--st-purple-hover); }
        .text-st-purple { color: var(--st-purple); }
        
        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #f1f1f1; border-radius: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #c1c1c1; border-radius: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #a8a8a8; }
        
        /* Стилізація чекбоксів */
        .filter-checkbox {
            appearance: none;
            background-color: #fff;
            margin: 0;
            font: inherit;
            color: currentColor;
            width: 1.15em;
            height: 1.15em;
            border: 1px solid #d1d5db;
            border-radius: 0.15em;
            display: grid;
            place-content: center;
            cursor: pointer;
            transition: all 0.2s ease-in-out;
        }
        .filter-checkbox::before {
            content: "";
            width: 0.65em;
            height: 0.65em;
            transform: scale(0);
            transition: 120ms transform ease-in-out;
            box-shadow: inset 1em 1em white;
            background-color: white;
            transform-origin: bottom left;
            clip-path: polygon(14% 44%, 0 65%, 50% 100%, 100% 16%, 80% 0%, 43% 62%);
        }
        .filter-checkbox:checked {
            background-color: var(--st-purple);
            border-color: var(--st-purple);
        }
        .filter-checkbox:checked::before {
            transform: scale(1);
        }
    </style>
</head>
<body class="text-gray-800">
    <div class="min-h-screen flex flex-col">
        <header class="bg-[#212121] border-b border-gray-900 sticky top-0 z-50 shadow-md text-white">
            <div class="max-w-[1400px] mx-auto px-4 h-[70px] flex items-center justify-between gap-4">
                <div class="flex items-center gap-4 shrink-0">
                    <button class="text-2xl hover:text-st-purple transition-colors md:hidden"><i class="fas fa-bars"></i></button>
                    <a href="/" class="flex items-center text-st-purple text-2xl font-bold tracking-tight cursor-pointer">
                        <i class="fas fa-layer-group mr-2 text-2xl"></i>
                        <span>SmartTab</span>
                    </a>
                </div>

                <div class="flex-1 max-w-2xl mx-8 relative hidden md:flex items-center">
                    <input type="text" id="searchInput" placeholder="Я шукаю..." 
                           class="w-full py-2.5 px-4 pr-[100px] rounded border-none text-sm focus:ring-2 focus:ring-st-purple text-black bg-white outline-none shadow-inner" 
                           oninput="applyFilters()">
                    <button class="absolute right-0 top-0 h-full px-6 bg-st-purple hover:bg-st-purple-hover transition-colors text-white text-sm font-medium rounded-r">
                        Знайти
                    </button>
                </div>
                
                <div class="flex items-center gap-6 shrink-0">
                    <a href="/Home/Privacy" class="flex items-center gap-2 text-white hover:text-gray-300 transition-colors group">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:text-st-purple transition-colors"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                        <span class="font-medium text-[15px]">Вхід</span>
                    </a>
                    
                    <button onclick="toggleCart()" class="flex items-center gap-2 bg-[#2a2a2a] hover:bg-[#333] border border-gray-700 px-4 py-2 rounded-lg text-white transition-colors relative">
                        <i class="fas fa-shopping-cart text-st-purple"></i>
                        <span class="font-medium text-[15px]">Кошик</span>
                        <span id="cart-count" class="absolute -top-2 -right-2 bg-st-purple text-white text-xs font-bold h-5 min-w-[20px] flex items-center justify-center rounded-full px-1 shadow">0</span>
                    </button>
                </div>
            </div>
            
            <div class="md:hidden p-3 bg-[#212121] border-t border-gray-700">
                <input type="text" id="mobileSearchInput" placeholder="Я шукаю..." class="w-full py-2 px-4 rounded text-black outline-none" oninput="document.getElementById('searchInput').value = this.value; applyFilters();">
            </div>
        </header>

        <div class="max-w-[1400px] mx-auto w-full px-4 py-6 flex flex-col md:flex-row gap-6 items-start">
            
            <aside class="w-full md:w-[280px] shrink-0 bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden sticky top-[94px]">
                <div class="p-4 bg-gray-50 border-b border-gray-200 flex justify-between items-center">
                    <h2 class="font-bold text-gray-800 text-lg flex items-center gap-2">
                        <i class="fas fa-filter text-st-purple"></i> Фільтри
                    </h2>
                    <button onclick="resetFilters()" class="text-sm text-gray-500 hover:text-st-purple hover:underline">Очистити</button>
                </div>
                
                <div class="custom-scrollbar overflow-y-auto max-h-[calc(100vh-180px)]">
                    <div class="p-5 border-b border-gray-100">
                        <h3 class="font-bold text-gray-900 mb-4 text-[15px]">Категорії</h3>
                        <div id="category-filters" class="space-y-3">
                            <div class="text-gray-400 text-sm animate-pulse">Завантаження...</div>
                        </div>
                    </div>

                    <div class="p-5">
                        <h3 class="font-bold text-gray-900 mb-4 text-[15px]">Виробники</h3>
                        <div id="manufacturer-filters" class="space-y-3">
                            <div class="text-gray-400 text-sm animate-pulse">Завантаження...</div>
                        </div>
                    </div>
                </div>
            </aside>

            <main class="flex-1 w-full bg-white rounded-lg shadow-sm border border-gray-200 p-6 min-h-[500px]">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-gray-100">
                    <h1 class="text-2xl font-bold text-gray-900">Всі товари <span id="product-count-label" class="text-gray-500 font-normal ml-2 text-lg">0</span></h1>
                </div>
                
                <div id="products-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
                    <div class="col-span-full py-20 flex flex-col items-center justify-center text-gray-400">
                        <i class="fas fa-circle-notch fa-spin text-4xl text-st-purple mb-4"></i>
                        <p>Завантаження товарів...</p>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <div id="cart-overlay" class="fixed inset-0 bg-black/50 z-[60] hidden transition-opacity opacity-0" onclick="toggleCart()"></div>
    <div id="cart-panel" class="fixed top-0 right-0 h-full w-full sm:w-[400px] bg-white z-[70] shadow-2xl transform translate-x-full transition-transform duration-300 flex flex-col">
        <div class="p-5 border-b flex justify-between items-center bg-gray-50">
            <h2 class="text-xl font-bold text-gray-900 flex items-center gap-2">
                <i class="fas fa-shopping-cart text-st-purple"></i> Ваш кошик
            </h2>
            <button onclick="toggleCart()" class="text-gray-400 hover:text-red-500 text-xl w-8 h-8 flex items-center justify-center rounded-full hover:bg-gray-200 transition-colors">
                <i class="fas fa-times"></i>
            </button>
        </div>
        
        <div id="cart-items" class="flex-1 p-5 overflow-y-auto custom-scrollbar space-y-4">
            </div>

        <div class="p-5 border-t bg-gray-50">
            <div class="flex justify-between items-center mb-4 text-lg font-bold text-gray-900">
                <span>Разом до сплати:</span>
                <span id="cart-total" class="text-2xl text-st-purple">0 ₴</span>
            </div>
            <button onclick="checkout()" class="w-full bg-st-purple hover:bg-st-purple-hover text-white py-3.5 rounded-lg font-bold text-lg transition-colors shadow-lg shadow-purple-500/30">
                Оформити замовлення
            </button>
        </div>
    </div>

    <script>
        let allProducts = [];
        let allManufacturers = [];
        let allCategories = [];
        let cart = [];

        document.addEventListener('DOMContentLoaded', () => {
            loadData();
            loadCart();
        });

        function loadData() {
            Promise.all([
                fetch('/api/categories').then(res => res.json()).catch(() => []),
                fetch('/api/manufacturers').then(res => res.json()).catch(() => []),
                fetch('/api/products').then(res => res.json()).catch(() => [])
            ]).then(([categories, manufacturers, products]) => {
                allCategories = categories;
                allManufacturers = manufacturers;
                allProducts = products;
                
                renderFilters();
                applyFilters();
            });
        }

        function renderFilters() {
            // Рендер категорій
            const catContainer = document.getElementById('category-filters');
            if (allCategories.length === 0) {
                catContainer.innerHTML = '<p class="text-gray-400 text-sm">Категорії відсутні</p>';
            } else {
                catContainer.innerHTML = allCategories.map(c => `
                    <label class="flex items-center space-x-3 cursor-pointer group py-1">
                        <input type="checkbox" value="${c.id}" class="filter-checkbox cat-cb" onchange="applyFilters()">
                        <span class="text-gray-700 group-hover:text-st-purple transition-colors text-[14px] leading-tight">${c.name}</span>
                    </label>
                `).join('');
            }

            // Рендер виробників
            const mfgContainer = document.getElementById('manufacturer-filters');
            if (allManufacturers.length === 0) {
                mfgContainer.innerHTML = '<p class="text-gray-400 text-sm">Виробники відсутні</p>';
            } else {
                mfgContainer.innerHTML = allManufacturers.map(m => `
                    <label class="flex items-center space-x-3 cursor-pointer group py-1">
                        <input type="checkbox" value="${m.id}" class="filter-checkbox mfg-cb" onchange="applyFilters()">
                        <span class="text-gray-700 group-hover:text-st-purple transition-colors text-[14px] leading-tight">${m.name}</span>
                    </label>
                `).join('');
            }
        }

        function applyFilters() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase().trim();
            
            const selectedCats = Array.from(document.querySelectorAll('.cat-cb:checked')).map(cb => cb.value);
            const selectedMfgs = Array.from(document.querySelectorAll('.mfg-cb:checked')).map(cb => cb.value);

            const filteredProducts = allProducts.filter(p => {
                const matchesSearch = p.name.toLowerCase().includes(searchTerm);
                const matchesCat = selectedCats.length === 0 || selectedCats.includes(p.categoryId?.toString());
                const matchesMfg = selectedMfgs.length === 0 || selectedMfgs.includes(p.manufacturerId?.toString());
                
                return matchesSearch && matchesCat && matchesMfg;
            });

            renderProducts(filteredProducts);
        }

        function resetFilters() {
            document.getElementById('searchInput').value = '';
            document.getElementById('mobileSearchInput').value = '';
            document.querySelectorAll('.filter-checkbox').forEach(cb => cb.checked = false);
            applyFilters();
        }

        function renderProducts(products) {
            const grid = document.getElementById('products-grid');
            document.getElementById('product-count-label').innerText = products.length;

            if (products.length === 0) {
                grid.innerHTML = `
                    <div class="col-span-full py-20 flex flex-col items-center justify-center text-gray-500">
                        <i class="fas fa-search text-5xl text-gray-300 mb-4"></i>
                        <p class="text-lg">За вашим запитом нічого не знайдено</p>
                        <button onclick="resetFilters()" class="mt-4 text-st-purple hover:underline">Скинути фільтри</button>
                    </div>`;
                return;
            }

            let html = '';
            products.forEach(p => {
                let specsText = '';
                if (p.specs) {
                    try {
                        const parsed = typeof p.specs === 'string' ? JSON.parse(p.specs) : p.specs;
                        if (Array.isArray(parsed)) {
                            const vals = parsed.map(s => s.value).filter(Boolean);
                            if (vals.length > 0) specsText = vals.join(' / ');
                        } else if (typeof parsed === 'object') {
                            const vals = Object.values(parsed).filter(Boolean);
                            if (vals.length > 0) specsText = vals.join(' / ');
                        }
                    } catch(e) {}
                }

                const imageSrc = p.imageUrl ? p.imageUrl : 'data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="%23e5e7eb"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>';
                const mfgName = allManufacturers.find(m => m.id == p.manufacturerId)?.name || '';
                const isOutOfStock = !p.stockCount || p.stockCount <= 0;

                html += `
                <div class="border border-gray-200 rounded-xl p-4 flex flex-col hover:shadow-lg hover:border-st-purple/30 transition-all bg-white group">
                    <div class="h-[180px] mb-4 rounded overflow-hidden flex items-center justify-center p-2 relative">
                        <img src="${imageSrc}" alt="${p.name}" class="max-h-full max-w-full object-contain mix-blend-multiply transition-transform group-hover:scale-105">
                        ${isOutOfStock ? '<div class="absolute inset-0 bg-white/60 flex items-center justify-center"><span class="bg-gray-800 text-white text-xs font-bold px-3 py-1 rounded">Немає в наявності</span></div>' : ''}
                    </div>

                    ${mfgName ? `<div class="text-[12px] text-gray-500 font-medium mb-1 uppercase tracking-wider">${mfgName}</div>` : ''}
                    
                    <h3 class="font-bold text-gray-900 text-[15px] mb-2 leading-snug hover:text-st-purple cursor-pointer line-clamp-2" title="${p.name}">
                        ${p.name}
                    </h3>

                    <div class="text-[12px] text-gray-500 mb-4 leading-relaxed line-clamp-2 h-9">
                        ${specsText}
                    </div>

                    <div class="mt-auto pt-4 border-t border-gray-100 flex items-center justify-between">
                        <div class="text-xl font-black text-gray-900">${p.price} <span class="text-sm font-normal text-gray-500">₴</span></div>
                        <button onclick="addToCart(${p.id})" 
                                ${isOutOfStock ? 'disabled' : ''} 
                                class="w-10 h-10 rounded-full flex items-center justify-center transition-colors ${isOutOfStock ? 'bg-gray-100 text-gray-400 cursor-not-allowed' : 'bg-st-purple/10 text-st-purple hover:bg-st-purple hover:text-white'}"
                                title="В кошик">
                            <i class="fas fa-shopping-cart"></i>
                        </button>
                    </div>
                </div>`;
            });
            grid.innerHTML = html;
        }

        // --- Логіка кошика ---
        function loadCart() {
            const saved = localStorage.getItem('smarttab_cart');
            if (saved) {
                cart = JSON.parse(saved);
                updateCartUI();
            }
        }

        function saveCart() {
            localStorage.setItem('smarttab_cart', JSON.stringify(cart));
            updateCartUI();
        }

        function addToCart(productId) {
            const product = allProducts.find(p => p.id === productId);
            if (!product) return;

            const existingItem = cart.find(item => item.id === productId);
            if (existingItem) {
                if (existingItem.quantity < product.stockCount) {
                    existingItem.quantity += 1;
                } else {
                    alert('Досягнуто максимальної кількості на складі!');
                    return;
                }
            } else {
                cart.push({ ...product, quantity: 1 });
            }
            
            saveCart();
            
            // Анімація додавання
            const btn = event.currentTarget;
            btn.innerHTML = '<i class="fas fa-check"></i>';
            btn.classList.add('bg-green-500', 'text-white');
            btn.classList.remove('bg-st-purple/10', 'text-st-purple');
            setTimeout(() => {
                btn.innerHTML = '<i class="fas fa-shopping-cart"></i>';
                btn.classList.remove('bg-green-500', 'text-white');
                btn.classList.add('bg-st-purple/10', 'text-st-purple');
            }, 1000);
        }

        function removeFromCart(productId) {
            cart = cart.filter(item => item.id !== productId);
            saveCart();
        }

        function updateQuantity(productId, delta) {
            const item = cart.find(i => i.id === productId);
            if (item) {
                const newQty = item.quantity + delta;
                if (newQty > 0 && newQty <= item.stockCount) {
                    item.quantity = newQty;
                    saveCart();
                } else if (newQty === 0) {
                    removeFromCart(productId);
                }
            }
        }

        function updateCartUI() {
            // Оновлення лічильника в шапці
            const totalItems = cart.reduce((sum, item) => sum + item.quantity, 0);
            const countBadge = document.getElementById('cart-count');
            countBadge.innerText = totalItems;
            
            if (totalItems > 0) {
                countBadge.classList.remove('hidden');
                countBadge.classList.add('animate-bounce');
                setTimeout(() => countBadge.classList.remove('animate-bounce'), 300);
            } else {
                countBadge.classList.add('hidden');
            }

            // Рендер вмісту кошика
            const container = document.getElementById('cart-items');
            if (cart.length === 0) {
                container.innerHTML = `
                    <div class="flex flex-col items-center justify-center h-full text-gray-400 mt-20">
                        <i class="fas fa-shopping-basket text-6xl mb-4 text-gray-200"></i>
                        <p class="text-lg font-medium text-gray-600">Кошик порожній</p>
                        <p class="text-sm mt-2 text-center">Додайте товари з каталогу,<br>щоб оформити замовлення.</p>
                        <button onclick="toggleCart()" class="mt-6 text-st-purple font-medium hover:underline">Повернутись до покупок</button>
                    </div>`;
                document.getElementById('cart-total').innerText = '0 ₴';
                return;
            }

            let totalSum = 0;
            container.innerHTML = cart.map(item => {
                totalSum += item.price * item.quantity;
                const imageSrc = item.imageUrl ? item.imageUrl : 'https://via.placeholder.com/80';
                return `
                    <div class="flex gap-4 p-3 bg-white border border-gray-100 rounded-lg shadow-sm relative pr-10">
                        <img src="${imageSrc}" alt="${item.name}" class="w-20 h-20 object-contain rounded bg-gray-50 p-1">
                        <div class="flex-1">
                            <h4 class="text-sm font-bold text-gray-900 leading-tight mb-2 line-clamp-2">${item.name}</h4>
                            <div class="font-black text-st-purple mb-2">${item.price} ₴</div>
                            <div class="flex items-center gap-3">
                                <div class="flex items-center border border-gray-300 rounded bg-gray-50">
                                    <button onclick="updateQuantity(${item.id}, -1)" class="w-7 h-7 flex items-center justify-center hover:bg-gray-200 text-gray-600 transition-colors">-</button>
                                    <span class="w-8 text-center text-sm font-medium border-x border-gray-300">${item.quantity}</span>
                                    <button onclick="updateQuantity(${item.id}, 1)" class="w-7 h-7 flex items-center justify-center hover:bg-gray-200 text-gray-600 transition-colors" ${item.quantity >= item.stockCount ? 'disabled opacity-50' : ''}>+</button>
                                </div>
                            </div>
                        </div>
                        <button onclick="removeFromCart(${item.id})" class="absolute top-3 right-3 text-gray-300 hover:text-red-500 transition-colors" title="Видалити">
                            <i class="fas fa-trash-alt"></i>
                        </button>
                    </div>
                `;
            }).join('');

            document.getElementById('cart-total').innerText = `${totalSum} ₴`;
        }

        function toggleCart() {
            const panel = document.getElementById('cart-panel');
            const overlay = document.getElementById('cart-overlay');
            
            if (panel.classList.contains('translate-x-full')) {
                // Відкрити
                panel.classList.remove('translate-x-full');
                overlay.classList.remove('hidden');
                setTimeout(() => overlay.classList.remove('opacity-0'), 10);
                document.body.style.overflow = 'hidden'; // Заблокувати скрол сторінки
            } else {
                // Закрити
                panel.classList.add('translate-x-full');
                overlay.classList.add('opacity-0');
                setTimeout(() => overlay.classList.add('hidden'), 300);
                document.body.style.overflow = '';
            }
        }

        function checkout() {
            if (cart.length === 0) return;
            alert('Функціонал оформлення замовлення знаходиться в розробці!');
        }
    </script>
</body>
</html>