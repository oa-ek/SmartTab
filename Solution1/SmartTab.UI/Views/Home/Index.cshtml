@using System.Security.Claims
@{
    Layout = null;
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var userName = isAuthenticated ? User.Identity!.Name : "";
    var userRole = isAuthenticated ? User.FindFirst(ClaimTypes.Role)?.Value : "";
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SmartTab Store</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                fontFamily: {
                    sans: ['-apple-system', 'BlinkMacSystemFont', '"Segoe UI"', 'Roboto', 'Helvetica', 'Arial', 'sans-serif']
                }
            }
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --st-purple: #6f00ff;
            --st-purple-hover: #5b00d6;
        }
        body { 
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; 
            background-color: #f8f9fa; 
        }
        .bg-st-purple { background-color: var(--st-purple); }
        .text-st-purple { color: var(--st-purple); }
        
        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #f1f1f1; border-radius: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #c1c1c1; border-radius: 4px; }

        .filter-checkbox {
            appearance: none;
            width: 18px;
            height: 18px;
            border: 1px solid #d1d5db;
            border-radius: 4px;
            cursor: pointer;
            position: relative;
            transition: all 0.2s;
            background: white;
        }
        .filter-checkbox:checked {
            background-color: var(--st-purple);
            border-color: var(--st-purple);
        }
        .filter-checkbox:checked::after {
            content: "\f00c";
            font-family: "Font Awesome 6 Free";
            font-weight: 900;
            color: white;
            font-size: 10px;
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }
    </style>
</head>
<body class="text-gray-800">
    <div class="min-h-screen flex flex-col">
        <header class="bg-[#212121] border-b border-gray-900 sticky top-0 z-50 shadow-md text-white">
            <div class="max-w-[1400px] mx-auto px-4 h-[70px] flex items-center justify-between gap-4">
                
                <div class="flex items-center gap-4 shrink-0">
                    <button class="text-2xl hover:text-st-purple transition-colors md:hidden"><i class="fas fa-bars"></i></button>
                    
                    <a href="/" class="flex items-center text-st-purple text-2xl font-bold tracking-tight cursor-pointer">
                        <i class="fas fa-layer-group mr-2 text-2xl"></i>
                        <span>SmartTab</span>
                    </a>

                    <a href="/Home/ConfigPC" class="hidden md:flex items-center gap-2 bg-[#2a2a2a] hover:bg-[#333] border border-gray-700 px-4 py-2 rounded-lg text-white transition-colors ml-4">
                        <i class="fas fa-desktop text-st-purple"></i>
                        <span class="font-medium text-[14px]">Конфігуратор ПК</span>
                    </a>
                </div>

                <div class="flex-1 max-w-2xl mx-8 relative hidden md:flex items-center">
                    <input type="text" id="searchInput" placeholder="Я шукаю..." 
                           class="w-full py-2.5 px-4 pr-[100px] rounded border-none text-sm focus:ring-2 focus:ring-st-purple text-black bg-white outline-none shadow-inner" 
                           oninput="applyFilters()">
                    <button class="absolute right-0 top-0 h-full px-6 bg-st-purple hover:bg-st-purple-hover transition-colors text-white text-sm font-medium rounded-r">
                        Знайти
                    </button>
                </div>

                <div class="flex items-center gap-6 shrink-0">
                    @if (isAuthenticated)
                    {
                        <div class="relative" id="user-menu-wrapper">
                            <button id="user-menu-btn" onclick="toggleUserMenu()" class="flex items-center gap-2 text-white hover:text-st-purple transition-colors">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                                <span class="font-medium text-[15px] max-w-[120px] truncate">@userName</span>
                                <i id="user-menu-chevron" class="fas fa-chevron-down text-xs text-gray-400"></i>
                            </button>
                            <div id="user-menu-dropdown" class="absolute right-0 top-full mt-1 w-48 bg-white rounded-lg shadow-xl border border-gray-100 py-1 hidden z-50">
                                <a href="/Account/Profile" class="flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-st-purple">
                                    <i class="fas fa-user-circle w-4"></i> Мій профіль
                                </a>
                                @if (userRole == "Admin")
                                {
                                    <a href="/Home/Admin" class="flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-st-purple">
                                        <i class="fas fa-cog w-4"></i> Адмін панель
                                    </a>
                                }
                                <hr class="my-1 border-gray-100">
                                <form action="/Account/Logout" method="post" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="w-full flex items-center gap-2 px-4 py-2.5 text-sm text-red-500 hover:bg-red-50">
                                        <i class="fas fa-sign-out-alt w-4"></i> Вийти
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                    else
                    {
                        <a href="/Account/Login" class="flex items-center gap-2 text-white hover:text-st-purple transition-colors group">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                            <span class="font-medium text-[15px]">Вхід</span>
                        </a>
                    }

                    <button onclick="toggleCart()" class="flex items-center gap-2 bg-[#2a2a2a] hover:bg-[#333] border border-gray-700 px-4 py-2 rounded-lg text-white transition-colors relative">
                        <i class="fas fa-shopping-cart text-st-purple"></i>
                        <span class="font-medium text-[15px]">Кошик</span>
                        <span id="cart-count" class="absolute -top-2 -right-2 bg-st-purple text-white text-xs font-bold h-5 min-w-[20px] flex items-center justify-center rounded-full px-1 shadow">0</span>
                    </button>
                </div>
            </div>
        </header>

        <div class="max-w-[1400px] mx-auto w-full px-4 py-8 flex flex-col md:flex-row gap-8 items-start">
            <aside class="w-full md:w-[280px] shrink-0 bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden sticky top-24">
                <div class="p-4 bg-gray-50 border-b border-gray-200 flex justify-between items-center">
                    <h2 class="font-bold text-gray-800 text-lg flex items-center gap-2">
                        <i class="fas fa-filter text-st-purple"></i> Фільтри
                    </h2>
                    <button onclick="resetFilters()" class="text-sm text-gray-500 hover:text-st-purple">Очистити</button>
                </div>
                
                <div class="p-5 space-y-8">
                    <div>
                        <h3 class="font-bold text-gray-900 mb-4 text-[15px]">Категорії</h3>
                        <div id="category-filters" class="space-y-3 max-h-60 overflow-y-auto custom-scrollbar pr-2"></div>
                    </div>
                    <div>
                        <h3 class="font-bold text-gray-900 mb-4 text-[15px]">Виробники</h3>
                        <div id="manufacturer-filters" class="space-y-3 max-h-60 overflow-y-auto custom-scrollbar pr-2"></div>
                    </div>
                </div>
            </aside>

            <main class="flex-1">
                <div class="flex justify-between items-center mb-6">
                    <h1 class="text-2xl font-bold text-gray-900">Всі товари <span id="product-count-label" class="text-gray-400 font-normal ml-2 text-sm"></span></h1>
                </div>
                
                <div id="products-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                </div>
            </main>
        </div>
    </div>

    <div id="auth-modal-overlay" class="fixed inset-0 bg-black/60 z-[80] hidden flex items-center justify-center p-4" onclick="closeAuthModal(event)">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm p-8 relative" onclick="event.stopPropagation()">
            <button onclick="closeAuthModal()" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 text-xl"><i class="fas fa-times"></i></button>
            <div class="text-center mb-6">
                <div class="w-16 h-16 bg-st-purple/10 rounded-full flex items-center justify-center mx-auto mb-4"><i class="fas fa-lock text-st-purple text-2xl"></i></div>
                <h3 class="text-xl font-bold text-gray-900">Потрібна авторизація</h3>
                <p class="text-gray-500 text-sm mt-2">Щоб додати товар до кошика,<br>увійдіть або зареєструйтесь</p>
            </div>
            <div class="space-y-3">
                <a href="/Account/Login" class="w-full flex justify-center items-center py-3 px-4 rounded-lg font-bold text-white bg-[#6f00ff] hover:bg-[#5b00d6] transition-colors">Увійти</a>
                <a href="/Home/Privacy" class="w-full flex justify-center items-center py-3 px-4 rounded-lg font-bold text-[#6f00ff] border-2 border-[#6f00ff] hover:bg-purple-50 transition-colors">Зареєструватись</a>
            </div>
        </div>
    </div>

    <div id="cart-overlay" class="fixed inset-0 bg-black/50 z-[60] hidden transition-opacity opacity-0" onclick="toggleCart()"></div>
    <div id="cart-panel" class="fixed top-0 right-0 h-full w-full sm:w-[400px] bg-white z-[70] shadow-2xl transform translate-x-full transition-transform duration-300 flex flex-col">
        <div class="p-5 border-b flex justify-between items-center bg-gray-50">
            <h2 class="text-xl font-bold text-gray-900 flex items-center gap-2"><i class="fas fa-shopping-cart text-st-purple"></i> Ваш кошик</h2>
            <button onclick="toggleCart()" class="text-gray-400 hover:text-red-500 text-xl"><i class="fas fa-times"></i></button>
        </div>
        <div id="cart-items" class="flex-1 p-5 overflow-y-auto custom-scrollbar space-y-4"></div>
        <div class="p-5 border-t bg-gray-50">
            <div class="flex justify-between items-center mb-4 text-lg font-bold">
                <span>Разом:</span>
                <span id="cart-total" class="text-2xl text-st-purple">0 ₴</span>
            </div>
            <button onclick="checkout()" class="w-full bg-st-purple hover:bg-st-purple-hover text-white py-3.5 rounded-lg font-bold transition-all shadow-lg shadow-purple-500/30">Оформити замовлення</button>
        </div>
    </div>

    <script>
        const IS_AUTHENTICATED = @(isAuthenticated ? "true" : "false");
        let allProducts = [], allManufacturers = [], allCategories = [], cart = [];

        document.addEventListener('DOMContentLoaded', () => { loadData(); loadCart(); });

        function toggleUserMenu() {
            const drop = document.getElementById('user-menu-dropdown');
            const chevron = document.getElementById('user-menu-chevron');
            drop.classList.toggle('hidden');
            chevron?.classList.toggle('rotate-180');
        }

        function loadData() {
            Promise.all([
                fetch('/api/categories').then(res => res.json()).catch(() => []),
                fetch('/api/manufacturers').then(res => res.json()).catch(() => []),
                fetch('/api/products').then(res => res.json()).catch(() => [])
            ]).then(([categories, manufacturers, products]) => {
                allCategories = categories; allManufacturers = manufacturers; allProducts = products;
                renderFilters(); applyFilters();
            });
        }

        function renderFilters() {
            document.getElementById('category-filters').innerHTML = allCategories.map(c => `
                <label class="flex items-center space-x-3 cursor-pointer group py-1">
                    <input type="checkbox" value="${c.id}" class="filter-checkbox cat-cb" onchange="applyFilters()">
                    <span class="text-sm text-gray-600 group-hover:text-st-purple transition-colors">${c.name}</span>
                </label>`).join('');

            document.getElementById('manufacturer-filters').innerHTML = allManufacturers.map(m => `
                <label class="flex items-center space-x-3 cursor-pointer group py-1">
                    <input type="checkbox" value="${m.id}" class="filter-checkbox mfg-cb" onchange="applyFilters()">
                    <span class="text-sm text-gray-600 group-hover:text-st-purple transition-colors">${m.name}</span>
                </label>`).join('');
        }

        function applyFilters() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase().trim();
            const selectedCats = Array.from(document.querySelectorAll('.cat-cb:checked')).map(cb => cb.value);
            const selectedMfgs = Array.from(document.querySelectorAll('.mfg-cb:checked')).map(cb => cb.value);

            const filtered = allProducts.filter(p => {
                const matchesSearch = p.name.toLowerCase().includes(searchTerm);
                const matchesCat = selectedCats.length === 0 || selectedCats.includes(p.categoryId?.toString());
                const matchesMfg = selectedMfgs.length === 0 || selectedMfgs.includes(p.manufacturerId?.toString());
                return matchesSearch && matchesCat && matchesMfg;
            });
            renderProducts(filtered);
        }

        function resetFilters() {
            document.getElementById('searchInput').value = '';
            document.querySelectorAll('.filter-checkbox').forEach(cb => cb.checked = false);
            applyFilters();
        }

        function renderProducts(products) {
            const grid = document.getElementById('products-grid');
            document.getElementById('product-count-label').innerText = `${products.length} од.`;
            
            grid.innerHTML = products.map(p => {
                let specsText = '';
                if (p.specs) {
                    try {
                        const parsed = typeof p.specs === 'string' ? JSON.parse(p.specs) : p.specs;
                        const vals = Array.isArray(parsed) ? parsed.map(s => s.value) : Object.values(parsed);
                        specsText = vals.filter(Boolean).join(' / ');
                    } catch(e) {}
                }

                const imageHtml = p.imageUrl 
                    ? `<img src="${p.imageUrl}" class="max-h-full max-w-full object-contain transition-transform group-hover:scale-105">`
                    : `<i class="fas fa-image text-gray-200 text-5xl"></i>`;
                
                const mfgName = allManufacturers.find(m => m.id == p.manufacturerId)?.name || 'Brend';
                const isOutOfStock = !p.stockCount || p.stockCount <= 0;
                const productUrl = `/Home/ProductPage/${p.id}`;

                return `
                <div class="border border-gray-200 rounded-xl p-4 flex flex-col hover:shadow-lg transition-all bg-white group relative">
                    <a href="${productUrl}" class="h-[180px] mb-4 rounded-lg overflow-hidden flex items-center justify-center p-2 bg-white relative cursor-pointer">
                        ${imageHtml}
                        ${isOutOfStock ? '<div class="absolute inset-0 bg-white/60 flex items-center justify-center text-center"><span class="bg-gray-800 text-white text-[10px] font-bold px-2 py-1 rounded">НЕМАЄ В НАЯВНОСТІ</span></div>' : ''}
                    </a>

                    <div class="text-[12px] text-st-purple font-medium mb-1 uppercase tracking-wider">${mfgName}</div>
                    
                    <a href="${productUrl}" class="font-bold text-gray-900 text-[15px] mb-2 leading-snug line-clamp-2 h-10 group-hover:text-st-purple transition-colors cursor-pointer">
                        ${p.name}
                    </a>

                    <div class="text-[12px] text-gray-400 mb-4 line-clamp-2 h-9 italic">${specsText}</div>

                    <div class="mt-auto pt-3 border-t border-gray-100">
                        <div class="flex items-center justify-between">
                            <div class="text-2xl font-bold text-[#f84147] leading-none">${p.price} ₴</div>
                            
                            <button onclick="event.preventDefault(); event.stopPropagation(); addToCart(${p.id})" ${isOutOfStock ? 'disabled' : ''} 
                                    class="text-st-purple hover:text-st-purple-hover transition-colors p-1 ${isOutOfStock ? 'opacity-30 cursor-not-allowed' : ''}">
                                <i class="fas fa-shopping-cart text-xl"></i>
                            </button>
                        </div>
                        <div class="text-[13px] text-gray-500 mt-2">Залишок: <span class="font-bold text-gray-900">${p.stockCount || 0}</span> шт</div>
                    </div>
                </div>`;
            }).join('');
        }

        // --- Cart Logic ---
        function loadCart() {
            const saved = localStorage.getItem('smarttab_cart');
            if (saved) { cart = JSON.parse(saved); updateCartUI(); }
        }

        function saveCart() {
            localStorage.setItem('smarttab_cart', JSON.stringify(cart));
            updateCartUI();
        }

        function addToCart(productId) {
            if (!IS_AUTHENTICATED) {
                document.getElementById('auth-modal-overlay').classList.remove('hidden');
                return;
            }
            const product = allProducts.find(p => p.id === productId);
            if (!product) return;
            const existing = cart.find(i => i.id === productId);
            if (existing) {
                if (existing.quantity < product.stockCount) existing.quantity++;
                else { alert('Більше немає на складі!'); return; }
            } else {
                cart.push({ ...product, quantity: 1 });
            }
            saveCart();
            const cartBadge = document.getElementById('cart-count');
            cartBadge.classList.add('scale-125', 'text-yellow-300');
            setTimeout(() => cartBadge.classList.remove('scale-125', 'text-yellow-300'), 200);
        }

        function removeFromCart(id) { cart = cart.filter(i => i.id !== id); saveCart(); }

        function updateQuantity(id, delta) {
            const item = cart.find(i => i.id === id);
            if (item) {
                const newQty = item.quantity + delta;
                if (newQty > 0 && newQty <= item.stockCount) { item.quantity = newQty; saveCart(); }
                else if (newQty === 0) removeFromCart(id);
            }
        }

        function updateCartUI() {
            const totalItems = cart.reduce((sum, i) => sum + i.quantity, 0);
            document.getElementById('cart-count').innerText = totalItems;
            const container = document.getElementById('cart-items');
            if (cart.length === 0) {
                container.innerHTML = '<p class="text-center text-gray-400 mt-10">Кошик порожній</p>';
                document.getElementById('cart-total').innerText = '0 ₴';
                return;
            }
            let total = 0;
            container.innerHTML = cart.map(i => {
                total += i.price * i.quantity;
                return `
                <div class="flex gap-4 p-3 bg-white border border-gray-100 rounded-lg relative">
                    <img src="${i.imageUrl || ''}" class="w-16 h-16 object-contain">
                    <div class="flex-1">
                        <h4 class="text-sm font-bold line-clamp-1">${i.name}</h4>
                        <div class="text-st-purple font-bold">${i.price} ₴</div>
                        <div class="flex items-center gap-2 mt-1">
                            <button onclick="updateQuantity(${i.id}, -1)" class="w-6 h-6 border rounded hover:bg-gray-100">-</button>
                            <span class="text-sm font-medium">${i.quantity}</span>
                            <button onclick="updateQuantity(${i.id}, 1)" class="w-6 h-6 border rounded hover:bg-gray-100" ${i.quantity >= i.stockCount ? 'disabled opacity-50' : ''}>+</button>
                        </div>
                    </div>
                    <button onclick="removeFromCart(${i.id})" class="absolute top-2 right-2 text-gray-300 hover:text-red-500 transition-colors"><i class="fas fa-trash"></i></button>
                </div>`;
            }).join('');
            document.getElementById('cart-total').innerText = `${total} ₴`;
        }

        function toggleCart() {
            const panel = document.getElementById('cart-panel');
            const overlay = document.getElementById('cart-overlay');
            panel.classList.toggle('translate-x-full');
            overlay.classList.toggle('hidden');
            setTimeout(() => overlay.classList.toggle('opacity-0'), 10);
        }

        function closeAuthModal(e) { 
            if (e && e.target !== document.getElementById('auth-modal-overlay')) return;
            document.getElementById('auth-modal-overlay').classList.add('hidden'); 
        }
        
        function checkout() { 
            if(cart.length === 0) return;
            alert('Оформлення замовлення скоро буде!'); 
        }
    </script>
</body>
</html>