@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Реєстрація - SmartTab Store</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --st-purple: #6f00ff;
            --st-purple-hover: #5b00d6;
        }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; background-color: #f8f9fa; }
        .text-st-purple { color: var(--st-purple); }
        .bg-st-purple { background-color: var(--st-purple); }
        .hover\:bg-st-purple-hover:hover { background-color: var(--st-purple-hover); }
        
        .input-field {
            width: 100%;
            padding: 0.625rem 1rem;
            border: 1px solid #d1d5db;
            border-radius: 0.5rem;
            font-size: 0.875rem;
            outline: none;
            transition: all 0.2s;
        }
        .input-field:focus {
            border-color: var(--st-purple);
            box-shadow: 0 0 0 3px rgba(111, 0, 255, 0.1);
        }

        .checkbox-custom {
            appearance: none;
            background-color: #fff;
            margin: 0;
            width: 1.15em;
            height: 1.15em;
            border: 1px solid #d1d5db;
            border-radius: 0.2em;
            display: grid;
            place-content: center;
            cursor: pointer;
            transition: all 0.2s;
        }
        .checkbox-custom::before {
            content: "";
            width: 0.65em;
            height: 0.65em;
            transform: scale(0);
            transition: 120ms transform ease-in-out;
            box-shadow: inset 1em 1em white;
            background-color: white;
            transform-origin: bottom left;
            clip-path: polygon(14% 44%, 0 65%, 50% 100%, 100% 16%, 80% 0%, 43% 62%);
        }
        .checkbox-custom:checked {
            background-color: var(--st-purple);
            border-color: var(--st-purple);
        }
        .checkbox-custom:checked::before {
            transform: scale(1);
        }
    </style>
</head>
<body class="text-gray-800 flex flex-col min-h-screen">
    
    <header class="bg-[#212121] border-b border-gray-900 text-white">
        <div class="max-w-[1400px] mx-auto px-4 h-[70px] flex items-center justify-between">
            <a href="/" class="flex items-center text-st-purple text-2xl font-bold tracking-tight cursor-pointer">
                <i class="fas fa-layer-group mr-2 text-2xl"></i>
                <span>SmartTab</span>
            </a>
            <a href="/" class="text-sm font-medium text-gray-300 hover:text-white transition-colors flex items-center gap-2">
                <i class="fas fa-arrow-left"></i> На головну
            </a>
        </div>
    </header>

    <main class="flex-1 flex flex-col justify-center py-12 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
        
        <div class="absolute top-[-10%] left-[-10%] w-96 h-96 bg-st-purple/10 rounded-full blur-3xl"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-96 h-96 bg-st-purple/10 rounded-full blur-3xl"></div>

        <div class="sm:mx-auto sm:w-full sm:max-w-md relative z-10">
            <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900">
                Створити акаунт
            </h2>
            <p class="mt-2 text-center text-sm text-gray-600">
                Або
                <a href="/login" class="font-medium text-st-purple hover:underline transition-colors">
                    увійдіть, якщо вже зареєстровані
                </a>
            </p>
        </div>

        <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md relative z-10">
            <div class="bg-white py-8 px-4 shadow-xl border border-gray-100 sm:rounded-xl sm:px-10">
                <form class="space-y-5" onsubmit="handleRegister(event)">
                    
                    <div>
                        <label for="name" class="block text-sm font-medium text-gray-700 mb-1">
                            Прізвище та Ім'я
                        </label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-user text-gray-400 text-sm"></i>
                            </div>
                            <input id="name" name="name" type="text" required placeholder="Іванов Іван" maxlength="60" class="input-field pl-10" oninput="validateName(this)">
                        </div>
                        <p id="name-error" class="text-xs text-red-500 mt-1 hidden">Ім'я може містити лише літери, пробіл, апостроф та дефіс</p>
                    </div>

                    <div>
                        <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
                            Електронна пошта
                        </label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-envelope text-gray-400 text-sm"></i>
                            </div>
                            <input id="email" name="email" type="email" autocomplete="email" required placeholder="email@example.com" maxlength="100" class="input-field pl-10">
                        </div>
                    </div>

                    <div>
                        <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">
                            Номер телефону
                        </label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-phone text-gray-400 text-sm"></i>
                            </div>
                            <input id="phone" name="phone" type="tel" required placeholder="+380 (XX) XXX-XX-XX" maxlength="19" class="input-field pl-10" oninput="phoneMask(this)" onkeydown="phoneKeydown(event, this)">
                        </div>
                        <p id="phone-error" class="text-xs text-red-500 mt-1 hidden">Введіть номер у форматі +380 (XX) XXX-XX-XX</p>
                    </div>

                    <div>
                        <label for="password" class="block text-sm font-medium text-gray-700 mb-1">
                            Пароль
                        </label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-lock text-gray-400 text-sm"></i>
                            </div>
                            <input id="password" name="password" type="password" required placeholder="••••••••" maxlength="64" minlength="6" class="input-field pl-10" oninput="checkPasswords()">
                            <button type="button" onclick="togglePassword('password')" class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-gray-600">
                                <i class="fas fa-eye" id="eye-password"></i>
                            </button>
                        </div>
                    </div>

                    <div>
                        <label for="confirm_password" class="block text-sm font-medium text-gray-700 mb-1">
                            Підтвердження паролю
                        </label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-lock text-gray-400 text-sm"></i>
                            </div>
                            <input id="confirm_password" name="confirm_password" type="password" required placeholder="••••••••" maxlength="64" class="input-field pl-10" oninput="checkPasswords()">
                            <button type="button" onclick="togglePassword('confirm_password')" class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-gray-600">
                                <i class="fas fa-eye" id="eye-confirm_password"></i>
                            </button>
                        </div>
                        <p id="password-error" class="text-xs text-red-500 mt-1 hidden">Паролі не співпадають</p>
                    </div>

                    <div class="flex items-start mt-4">
                        <div class="flex items-center h-5">
                            <input id="terms" name="terms" type="checkbox" required class="checkbox-custom text-sm">
                        </div>
                        <div class="ml-3 text-sm">
                            <label for="terms" class="font-medium text-gray-700">Я погоджуюсь з <a href="#" class="text-st-purple hover:underline">Умовами використання</a> та <a href="#" class="text-st-purple hover:underline">Політикою конфіденційності</a></label>
                        </div>
                    </div>

                    <div class="pt-2">
                        <button type="submit" id="submit-btn" class="w-full flex justify-center items-center py-3 px-4 border border-transparent rounded-lg shadow-sm text-sm font-bold text-white bg-st-purple hover:bg-st-purple-hover focus:outline-none transition-colors shadow-lg shadow-purple-500/30">
                            Зареєструватися
                        </button>
                    </div>
                </form>

            </div>
        </div>
    </main>

    <script>
        // Валідація імені - тільки літери, пробіли, апостроф, дефіс
        function validateName(input) {
            const allowed = /^[а-яА-ЯіІїЇєЄґҐa-zA-Z\s'\-']+$/u;
            const err = document.getElementById('name-error');
            // Видаляємо заборонені символи одразу при введенні
            input.value = input.value.replace(/[^а-яА-ЯіІїЇєЄґҐa-zA-Z\s'\-']/gu, '');
            if (input.value.length > 0 && !allowed.test(input.value)) {
                err.classList.remove('hidden');
                input.classList.add('border-red-400');
            } else {
                err.classList.add('hidden');
                input.classList.remove('border-red-400');
            }
        }

        // Маска телефону: +380 (XX) XXX-XX-XX
        function phoneMask(input) {
            let digits = input.value.replace(/\D/g, '');

            // Завжди починаємо з 380
            if (digits.startsWith('380')) {
                // вже правильно
            } else if (digits.startsWith('38')) {
                digits = '380' + digits.substring(2);
            } else if (digits.startsWith('0')) {
                digits = '380' + digits.substring(1);
            } else {
                digits = '380' + digits.replace(/^3?8?0?/, '');
            }

            // Обмежуємо до 12 цифр (380 + 9 цифр номеру)
            digits = digits.substring(0, 12);

            // Формат: +380 (XX) XXX-XX-XX
            let formatted = '+380';
            if (digits.length > 3) {
                formatted += ' (' + digits.substring(3, Math.min(5, digits.length));
                if (digits.length >= 5) {
                    formatted += ') ' + digits.substring(5, Math.min(8, digits.length));
                    if (digits.length >= 8) {
                        formatted += '-' + digits.substring(8, Math.min(10, digits.length));
                        if (digits.length >= 10) {
                            formatted += '-' + digits.substring(10, 12);
                        }
                    }
                }
            }

            input.value = formatted;

            // Показуємо помилку тільки якщо поле не порожнє і неповне
            const err = document.getElementById('phone-error');
            const digitsOnly = input.value.replace(/\D/g, '');
            if (input.value.length > 0 && digitsOnly.length < 12) {
                err.classList.remove('hidden');
                input.classList.add('border-red-400');
            } else {
                err.classList.add('hidden');
                input.classList.remove('border-red-400');
            }
        }

        function phoneKeydown(event, input) {
            // Дозволяємо: Tab, стрілки, Ctrl+A/C/V/X
            const nav = [9, 13, 37, 38, 39, 40];
            if (nav.includes(event.keyCode)) return;
            if ((event.ctrlKey || event.metaKey) && [65, 67, 86, 88].includes(event.keyCode)) return;

            // Backspace - вручну видаляємо останню ЦИФРУ, ігноруючи форматні символи
            if (event.keyCode === 8) {
                event.preventDefault();
                let digits = input.value.replace(/\D/g, '');
                if (digits.length <= 3) {
                    // Залишилось тільки "380" або менше — повністю очищаємо
                    input.value = '';
                    document.getElementById('phone-error').classList.add('hidden');
                    input.classList.remove('border-red-400');
                } else {
                    // Видаляємо останню цифру і переформатовуємо
                    digits = digits.substring(0, digits.length - 1);
                    let formatted = '+380';
                    if (digits.length > 3) {
                        formatted += ' (' + digits.substring(3, Math.min(5, digits.length));
                        if (digits.length >= 5) {
                            formatted += ') ' + digits.substring(5, Math.min(8, digits.length));
                            if (digits.length >= 8) {
                                formatted += '-' + digits.substring(8, Math.min(10, digits.length));
                                if (digits.length >= 10) {
                                    formatted += '-' + digits.substring(10, 12);
                                }
                            }
                        }
                    }
                    input.value = formatted;
                    const err = document.getElementById('phone-error');
                    if (digits.length < 12) {
                        err.classList.remove('hidden');
                        input.classList.add('border-red-400');
                    } else {
                        err.classList.add('hidden');
                        input.classList.remove('border-red-400');
                    }
                }
                return;
            }

            // Delete — очищаємо поле повністю
            if (event.keyCode === 46) {
                event.preventDefault();
                input.value = '';
                document.getElementById('phone-error').classList.add('hidden');
                input.classList.remove('border-red-400');
                return;
            }

            // Блокуємо все крім цифр
            if (event.key < '0' || event.key > '9') {
                event.preventDefault();
            }
        }

        function togglePassword(inputId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById('eye-' + inputId);
            
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            }
        }

        function checkPasswords() {
            const password = document.getElementById('password').value;
            const confirm = document.getElementById('confirm_password').value;
            const errorMsg = document.getElementById('password-error');
            const submitBtn = document.getElementById('submit-btn');

            if (confirm.length > 0) {
                if (password !== confirm) {
                    errorMsg.classList.remove('hidden');
                    submitBtn.disabled = true;
                    submitBtn.classList.add('opacity-50', 'cursor-not-allowed');
                } else {
                    errorMsg.classList.add('hidden');
                    submitBtn.disabled = false;
                    submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                }
            } else {
                errorMsg.classList.add('hidden');
            }
        }

        function handleRegister(event) {
            event.preventDefault();
            const password = document.getElementById('password').value;
            const confirm = document.getElementById('confirm_password').value;

            if (password !== confirm) {
                return;
            }

            const btn = document.getElementById('submit-btn');
            const originalText = btn.innerHTML;
            
            btn.innerHTML = '<i class="fas fa-circle-notch fa-spin mr-2"></i> Створення...';
            btn.disabled = true;

            // Імітація запиту до API
            setTimeout(() => {
                btn.innerHTML = '<i class="fas fa-check mr-2"></i> Успішно!';
                btn.classList.replace('bg-st-purple', 'bg-green-500');
                btn.classList.replace('hover:bg-st-purple-hover', 'hover:bg-green-600');
                
                setTimeout(() => {
                    alert('Реєстрація успішна! (Імітація)');
                    window.location.href = '/login';
                }, 1000);
            }, 1500);
        }
    </script>
</body>
</html>