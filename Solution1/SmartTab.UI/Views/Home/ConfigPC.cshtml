@using System.Security.Claims
@{
    Layout = null;
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var userName = isAuthenticated ? User.Identity!.Name : "";
    var userRole = isAuthenticated ? User.FindFirst(ClaimTypes.Role)?.Value : "";
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SmartTab | Конфігуратор ПК</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                fontFamily: {
                    sans: ['-apple-system', 'BlinkMacSystemFont', '"Segoe UI"', 'Roboto', 'Helvetica', 'Arial', 'sans-serif']
                }
            }
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --st-purple: #6f00ff;
            --st-purple-hover: #5b00d6;
        }
        body { 
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; 
            background-color: #f8f9fa; 
        }
        .bg-st-purple { background-color: var(--st-purple); }
        .text-st-purple { color: var(--st-purple); }
        
        .loader {
            border-top-color: #6f00ff;
            animation: spinner 0.6s linear infinite;
        }
        @@keyframes spinner {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #f1f1f1; border-radius: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #c1c1c1; border-radius: 4px; }
    </style>
</head>
<body class="text-gray-800">
    <div class="min-h-screen flex flex-col">
        <header class="bg-[#212121] border-b border-gray-900 sticky top-0 z-50 shadow-md text-white">
            <div class="max-w-[1400px] mx-auto px-4 h-[70px] flex items-center justify-between gap-4">
                <div class="flex items-center gap-4 shrink-0">
                    <button class="text-2xl hover:text-st-purple transition-colors md:hidden"><i class="fas fa-bars"></i></button>
                    <a href="/" class="flex items-center text-st-purple text-2xl font-bold tracking-tight cursor-pointer">
                        <i class="fas fa-layer-group mr-2 text-2xl"></i>
                        <span>SmartTab</span>
                    </a>
                    <a href="/Home/ConfigPC" class="hidden md:flex items-center gap-2 bg-st-purple border border-st-purple px-4 py-2 rounded-lg text-white transition-colors ml-4 shadow-lg shadow-purple-500/20">
                        <i class="fas fa-desktop"></i>
                        <span class="font-bold text-[14px]">Конфігуратор ПК</span>
                    </a>
                </div>

                <div class="flex items-center gap-6 shrink-0 ml-auto">
                    <a href="/" class="text-sm font-medium hover:text-st-purple transition-colors mr-2">До каталогу</a>
                    
                    @if (isAuthenticated)
                    {
                        <span id="user-balance-badge" class="text-xs font-bold bg-green-500/20 text-green-400 px-2 py-0.5 rounded-full hidden"></span>
                        <div class="relative" id="user-menu-wrapper">
                            <button onclick="toggleUserMenu()" class="flex items-center gap-2 text-white hover:text-st-purple transition-colors">
                                <i class="fas fa-user-circle text-xl text-st-purple"></i>
                                <span class="font-medium text-[15px] hidden sm:block">@userName</span>
                            </button>
                        </div>
                    }
                    else
                    {
                        <a href="/Account/Login" class="flex items-center gap-2 text-white hover:text-st-purple transition-colors group">
                            <i class="fas fa-sign-in-alt text-lg text-st-purple"></i>
                            <span class="font-medium text-[15px]">Вхід</span>
                        </a>
                    }

                    <button onclick="toggleCart()" class="flex items-center gap-2 bg-[#2a2a2a] hover:bg-[#333] border border-gray-700 px-4 py-2 rounded-lg text-white transition-colors relative">
                        <i class="fas fa-shopping-cart text-st-purple"></i>
                        <span class="font-medium text-[15px]">Кошик</span>
                        <span id="cart-count" class="absolute -top-2 -right-2 bg-st-purple text-white text-xs font-bold h-5 min-w-[20px] flex items-center justify-center rounded-full px-1 shadow">0</span>
                    </button>
                </div>
            </div>
        </header>

        <main class="max-w-[1400px] mx-auto w-full px-4 py-8">
            <div class="mb-8 text-center">
                <h1 class="text-4xl font-black text-gray-900 mb-3">Збери свій ідеальний ПК</h1>
                <p class="text-gray-500">Оберіть сумісні комплектуючі, а ми зберемо їх для вас.</p>
            </div>

            <div id="loading-state" class="flex flex-col items-center justify-center py-20">
                <div class="loader ease-linear rounded-full border-4 border-t-4 border-gray-200 h-12 w-12 mb-4"></div>
                <p class="text-gray-400 font-medium">Завантаження каталогу комплектуючих...</p>
            </div>

            <div id="configurator-content" class="hidden grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
                
                <div class="lg:col-span-8 space-y-4" id="slots-container">
                    </div>

                <div class="lg:col-span-4 sticky top-24">
                    <div class="bg-white rounded-[2rem] p-8 shadow-sm border border-gray-100">
                        <h2 class="text-xl font-black mb-6 text-gray-900 flex items-center gap-3">
                            <i class="fas fa-receipt text-st-purple"></i> Підсумок збірки
                        </h2>
                        
                        <div id="summary-items" class="space-y-3 mb-6 min-h-[100px]">
                            <p class="text-gray-400 text-sm italic text-center mt-8">Ви ще не обрали жодної деталі</p>
                        </div>

                        <div class="border-t border-gray-100 pt-6 mt-4">
                            <div class="text-gray-400 text-sm font-bold uppercase mb-2">Загальна вартість</div>
                            <div class="flex items-baseline gap-2">
                                <span id="total-price" class="text-4xl font-black text-[#f84147] leading-none">0</span>
                                <span class="text-xl font-bold text-gray-400">₴</span>
                            </div>
                        </div>

                        <button onclick="buyBuild()" class="w-full mt-8 bg-st-purple hover:bg-st-purple-hover text-white font-black py-4 rounded-2xl transition-all shadow-lg shadow-purple-500/30 uppercase tracking-wider flex items-center justify-center gap-3">
                            <i class="fas fa-cart-plus text-xl"></i>
                            Додати в кошик
                        </button>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <div id="selection-modal" class="fixed inset-0 bg-black/60 z-[90] hidden flex items-center justify-center p-4 transition-opacity opacity-0" onclick="closeSelectionModal()">
        <div class="bg-white rounded-3xl shadow-2xl w-full max-w-5xl h-[85vh] flex flex-col relative overflow-hidden" onclick="event.stopPropagation()">
            
            <div class="p-6 border-b border-gray-100 flex justify-between items-center bg-gray-50">
                <div>
                    <h3 class="text-xl font-black text-gray-900" id="modal-title">Вибір компонента</h3>
                    <p class="text-sm text-gray-500 mt-1" id="modal-subtitle">Оберіть деталь зі списку</p>
                </div>
                <button onclick="closeSelectionModal()" class="w-10 h-10 flex items-center justify-center rounded-full bg-white border border-gray-200 text-gray-500 hover:text-red-500 hover:border-red-200 transition-colors shadow-sm">
                    <i class="fas fa-times text-lg"></i>
                </button>
            </div>
            
            <div class="p-4 border-b border-gray-100 relative">
                <i class="fas fa-search absolute left-8 top-1/2 -translate-y-1/2 text-gray-400"></i>
                <input type="text" id="modal-search" placeholder="Пошук моделі..." class="w-full bg-gray-50 border border-gray-200 rounded-xl py-3 pl-12 pr-4 focus:ring-2 focus:ring-st-purple focus:border-st-purple outline-none transition-all" oninput="filterModalProducts()">
            </div>

            <div class="flex-1 p-6 overflow-y-auto custom-scrollbar bg-gray-50/50">
                <div id="modal-products-grid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
                    </div>
            </div>
        </div>
    </div>

    <div id="auth-modal-overlay" class="fixed inset-0 bg-black/60 z-[100] hidden flex items-center justify-center p-4" onclick="closeAuthModal(event)">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm p-8 relative" onclick="event.stopPropagation()">
            <button onclick="closeAuthModal()" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 text-xl"><i class="fas fa-times"></i></button>
            <div class="text-center mb-6">
                <div class="w-16 h-16 bg-st-purple/10 rounded-full flex items-center justify-center mx-auto mb-4"><i class="fas fa-lock text-st-purple text-2xl"></i></div>
                <h3 class="text-xl font-bold text-gray-900">Потрібна авторизація</h3>
                <p class="text-gray-500 text-sm mt-2">Щоб додати збірку до кошика,<br>увійдіть або зареєструйтесь</p>
            </div>
            <div class="space-y-3">
                <a href="/Account/Login" class="w-full flex justify-center items-center py-3 px-4 rounded-lg font-bold text-white bg-[#6f00ff] hover:bg-[#5b00d6] transition-colors">Увійти</a>
                <a href="/Home/Privacy" class="w-full flex justify-center items-center py-3 px-4 rounded-lg font-bold text-[#6f00ff] border-2 border-[#6f00ff] hover:bg-purple-50 transition-colors">Зареєструватись</a>
            </div>
        </div>
    </div>

    <div id="cart-overlay" class="fixed inset-0 bg-black/50 z-[80] hidden transition-opacity opacity-0" onclick="toggleCart()"></div>
    <div id="cart-panel" class="fixed top-0 right-0 h-full w-full sm:w-[400px] bg-white z-[85] shadow-2xl transform translate-x-full transition-transform duration-300 flex flex-col">
        <div class="p-5 border-b flex justify-between items-center bg-gray-50">
            <h2 class="text-xl font-bold text-gray-900 flex items-center gap-2"><i class="fas fa-shopping-cart text-st-purple"></i> Ваш кошик</h2>
            <button onclick="toggleCart()" class="text-gray-400 hover:text-red-500 text-xl w-8 h-8 flex items-center justify-center rounded-full hover:bg-gray-200 transition-colors"><i class="fas fa-times"></i></button>
        </div>
        <div id="cart-items" class="flex-1 p-5 overflow-y-auto custom-scrollbar space-y-4"></div>
        <div class="p-5 border-t bg-gray-50">
            <div class="flex justify-between items-center mb-4 text-lg font-bold">
                <span>Разом:</span>
                <span id="cart-total" class="text-2xl text-[#f84147] font-black">0 ₴</span>
            </div>
            <button id="checkout-btn" onclick="checkout()" class="w-full bg-st-purple hover:bg-st-purple-hover text-white py-4 rounded-xl font-black uppercase tracking-wider transition-all shadow-lg shadow-purple-500/30">Оформити замовлення</button>
        </div>
    </div>

    <script>
        const IS_AUTHENTICATED = @(isAuthenticated ? "true" : "false");
        let allProducts = [], allCategories = [], cart = [];
        
        // Слоти для збірки ПК та ключові слова для пошуку відповідних категорій у твоїй базі
        const configSlots = [
            { id: 'cpu', name: 'Процесор', icon: 'fa-microchip', keywords: ['процесор', 'cpu'] },
            { id: 'mb', name: 'Материнська плата', icon: 'fa-chess-board', keywords: ['материнська', 'motherboard', 'плата'] },
            { id: 'ram', name: 'Оперативна пам\'ять', icon: 'fa-memory', keywords: ['пам\'ять', 'ram', 'ddr'] },
            { id: 'gpu', name: 'Відеокарта', icon: 'fa-vr-cardboard', keywords: ['відеокарта', 'gpu', 'графічн'] },
            { id: 'cooler', name: 'Охолодження', icon: 'fa-fan', keywords: ['охолодження', 'cooler', 'кулер'] },
            { id: 'storage', name: 'Накопичувач (SSD/HDD)', icon: 'fa-hdd', keywords: ['ssd', 'hdd', 'накопичувач', 'диск', 'жорсткий'] },
            { id: 'psu', name: 'Блок живлення', icon: 'fa-plug', keywords: ['блок живлення', 'psu', 'живлення'] },
            { id: 'case', name: 'Корпус', icon: 'fa-box', keywords: ['корпус', 'case'] }
        ];

        // Зберігає вибрані товари (ключ - id слота)
        let selectedBuild = {};
        let currentModalSlotId = null;

        document.addEventListener('DOMContentLoaded', () => { 
            loadData(); 
            if (IS_AUTHENTICATED) loadBalance();
        });

        async function loadData() {
            try {
                const [categoriesRes, productsRes] = await Promise.all([
                    fetch('/api/categories'),
                    fetch('/api/products')
                ]);
                allCategories = await categoriesRes.json();
                allProducts = await productsRes.json();
                
                renderSlots();
                loadCart();
                document.getElementById('loading-state').classList.add('hidden');
                document.getElementById('configurator-content').classList.remove('hidden');
            } catch (e) {
                document.getElementById('loading-state').innerHTML = `<div class="text-red-500 font-bold">Помилка завантаження даних</div>`;
            }
        }

        function renderSlots() {
            const container = document.getElementById('slots-container');
            container.innerHTML = configSlots.map(slot => {
                const selected = selectedBuild[slot.id];
                
                if (selected) {
                    // Слот із вибраним товаром
                    return `
                    <div class="bg-white rounded-2xl p-5 shadow-sm border border-st-purple/30 flex items-center justify-between group transition-all">
                        <div class="flex items-center gap-5">
                            <div class="w-14 h-14 bg-gray-50 rounded-xl flex items-center justify-center p-1 border border-gray-100 shrink-0">
                                <img src="${selected.imageUrl || ''}" class="max-w-full max-h-full object-contain" onerror="this.src=''; this.parentElement.innerHTML='<i class=\\'fas ${slot.icon} text-st-purple text-2xl\\'></i>'">
                            </div>
                            <div>
                                <div class="text-[11px] text-st-purple font-bold uppercase tracking-wider mb-1">${slot.name}</div>
                                <div class="font-bold text-gray-900 text-[15px] leading-tight line-clamp-1">${selected.name}</div>
                                <div class="text-[#f84147] font-black text-lg mt-1">${selected.price} ₴</div>
                            </div>
                        </div>
                        <div class="flex items-center gap-2 shrink-0">
                            <button onclick="openSelectionModal('${slot.id}')" class="w-10 h-10 rounded-xl bg-gray-50 text-gray-500 hover:text-st-purple hover:bg-purple-50 transition-colors" title="Змінити">
                                <i class="fas fa-sync-alt"></i>
                            </button>
                            <button onclick="removePart('${slot.id}')" class="w-10 h-10 rounded-xl bg-gray-50 text-gray-500 hover:text-red-500 hover:bg-red-50 transition-colors" title="Видалити">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>`;
                } else {
                    // Порожній слот
                    return `
                    <div class="bg-white rounded-2xl p-5 shadow-sm border border-dashed border-gray-300 flex items-center justify-between hover:border-st-purple transition-all">
                        <div class="flex items-center gap-5 opacity-70">
                            <div class="w-14 h-14 bg-gray-50 rounded-xl flex items-center justify-center border border-gray-100 shrink-0 text-gray-300">
                                <i class="fas ${slot.icon} text-2xl"></i>
                            </div>
                            <div>
                                <div class="text-[11px] text-gray-400 font-bold uppercase tracking-wider mb-1">${slot.name}</div>
                                <div class="font-medium text-gray-500">Не вибрано</div>
                            </div>
                        </div>
                        <button onclick="openSelectionModal('${slot.id}')" class="bg-st-purple/10 text-st-purple px-5 py-2.5 rounded-xl font-bold hover:bg-st-purple hover:text-white transition-all text-sm uppercase tracking-wide">
                            Вибрати
                        </button>
                    </div>`;
                }
            }).join('');
            
            updateSummary();
        }

        // --- Допоміжна функція для зчитування характеристик продукту ---
        function getSpec(product, specName) {
            if (!product || !product.specs) return null;
            const key = specName.toLowerCase().trim();
            // Точний збіг
            let spec = product.specs.find(s => s.name.toLowerCase().trim() === key);
            // Fallback: початок назви збігається (для 'Форм-фактор' → 'Форм-фактор (ATX/Mini-ITX)')
            if (!spec) spec = product.specs.find(s => s.name.toLowerCase().trim().startsWith(key));
            return spec ? spec.value.trim() : null;
        }

        // --- Перевірка сумісності компонента з уже вибраними ---
        function checkCompatibility(product, slotId) {
            const warnings = [];
            const mb = selectedBuild['mb'];
            const cpu = selectedBuild['cpu'];
            const gpu = selectedBuild['gpu'];
            const psu = selectedBuild['psu'];

            if (slotId === 'cpu') {
                // CPU ↔ MB: перевірка сокету
                if (mb) {
                    const mbSocket = getSpec(mb, 'Сокет');
                    const cpuSocket = getSpec(product, 'Сокет');
                    if (mbSocket && cpuSocket && mbSocket.toLowerCase() !== cpuSocket.toLowerCase()) {
                        warnings.push(`Сокет ${cpuSocket} не підходить до плати (${mbSocket})`);
                    }
                }
            }

            if (slotId === 'mb') {
                // MB ↔ CPU: перевірка сокету
                if (cpu) {
                    const cpuSocket = getSpec(cpu, 'Сокет');
                    const mbSocket = getSpec(product, 'Сокет');
                    if (cpuSocket && mbSocket && cpuSocket.toLowerCase() !== mbSocket.toLowerCase()) {
                        warnings.push(`Сокет плати ${mbSocket} не підходить до процесора (${cpuSocket})`);
                    }
                }
                // MB ↔ RAM: перевірка типу пам'яті
                const ram = selectedBuild['ram'];
                if (ram) {
                    const ramType = getSpec(ram, "Тип пам'яті");
                    const mbRamType = getSpec(product, "Тип пам'яті");
                    if (ramType && mbRamType && !ramType.toLowerCase().includes(mbRamType.toLowerCase()) && !mbRamType.toLowerCase().includes(ramType.toLowerCase())) {
                        warnings.push(`Плата підтримує ${mbRamType}, а ОЗП — ${ramType}`);
                    }
                }
            }

            if (slotId === 'ram') {
                // RAM ↔ MB: перевірка типу пам'яті
                if (mb) {
                    const mbRamType = getSpec(mb, "Тип пам'яті");
                    const ramType = getSpec(product, "Тип пам'яті");
                    if (mbRamType && ramType && !ramType.toLowerCase().includes(mbRamType.toLowerCase()) && !mbRamType.toLowerCase().includes(ramType.toLowerCase())) {
                        warnings.push(`ОЗП ${ramType} не підходить до плати (${mbRamType})`);
                    }
                }
            }

            if (slotId === 'gpu') {
                // GPU ↔ PSU: перевірка TDP vs потужність БЖ
                if (psu) {
                    const gpuTdp = parseInt(getSpec(product, 'Енергоспоживання (Вт)')) || 0;
                    const psuPower = parseInt(getSpec(psu, 'Потужність (Вт)')) || 0;
                    if (gpuTdp > 0 && psuPower > 0 && gpuTdp > psuPower * 0.7) {
                        warnings.push(`GPU споживає ${gpuTdp}Вт — рекомендовано БЖ від ${Math.ceil(gpuTdp / 0.7)}Вт (ваш: ${psuPower}Вт)`);
                    }
                }
            }

            if (slotId === 'psu') {
                // PSU ↔ GPU: перевірка потужності
                if (gpu) {
                    const gpuTdp = parseInt(getSpec(gpu, 'Енергоспоживання (Вт)')) || 0;
                    const psuPower = parseInt(getSpec(product, 'Потужність (Вт)')) || 0;
                    if (gpuTdp > 0 && psuPower > 0 && gpuTdp > psuPower * 0.7) {
                        warnings.push(`БЖ ${psuPower}Вт може бути замало для GPU (${gpuTdp}Вт TDP)`);
                    }
                }
                // PSU ↔ CPU: додатково перевірити TDP процесора
                if (cpu) {
                    const cpuTdp = parseInt(getSpec(cpu, 'TDP (Вт)')) || 0;
                    const gpuTdp = gpu ? (parseInt(getSpec(gpu, 'Енергоспоживання (Вт)')) || 0) : 0;
                    const psuPower = parseInt(getSpec(product, 'Потужність (Вт)')) || 0;
                    const totalTdp = cpuTdp + gpuTdp + 100; // +100Вт на інше
                    if (psuPower > 0 && totalTdp > psuPower) {
                        warnings.push(`Загальне споживання ~${totalTdp}Вт перевищує БЖ ${psuPower}Вт`);
                    }
                }
            }

            if (slotId === 'cooler') {
                // Cooler ↔ CPU/MB: перевірка сокету
                const targetSocket = cpu ? getSpec(cpu, 'Сокет') : (mb ? getSpec(mb, 'Сокет') : null);
                if (targetSocket) {
                    const coolerSocket = getSpec(product, 'Підтримувані сокети') || getSpec(product, 'Сокет');
                    if (coolerSocket && !coolerSocket.toLowerCase().includes(targetSocket.toLowerCase())) {
                        warnings.push(`Кулер для ${coolerSocket}, а процесор/плата — ${targetSocket}`);
                    }
                }
                // Cooler ↔ CPU: перевірка TDP
                if (cpu) {
                    const cpuTdp = parseInt(getSpec(cpu, 'TDP (Вт)')) || 0;
                    const coolerTdp = parseInt(getSpec(product, 'TDP')) || parseInt(getSpec(product, 'TDP (Вт)')) || 0;
                    if (cpuTdp > 0 && coolerTdp > 0 && coolerTdp < cpuTdp) {
                        warnings.push(`Кулер розрахований на ${coolerTdp}Вт, а CPU споживає ${cpuTdp}Вт`);
                    }
                }
            }

            if (slotId === 'case') {
                // Case ↔ MB: перевірка форм-фактору
                if (mb) {
                    const mbFF = getSpec(mb, 'Форм-фактор');
                    const caseFF = getSpec(product, 'Форм-фактор');
                    if (mbFF && caseFF) {
                        const mbSize = {'mini-itx':1,'m-itx':1,'itx':1,'micro-atx':2,'m-atx':2,'matx':2,'atx':3,'e-atx':4,'eatx':4};
                        const caseSizeVal = mbSize[caseFF.toLowerCase()] || 3;
                        const mbSizeVal = mbSize[mbFF.toLowerCase()] || 3;
                        if (mbSizeVal > caseSizeVal) {
                            warnings.push(`Плата ${mbFF} не влізе в корпус ${caseFF}`);
                        }
                    }
                }
            }

            return warnings;
        }

        // Логіка пошуку відповідних категорій
        function getEligibleProductsForSlot(slotId) {
            const slotDef = configSlots.find(s => s.id === slotId);
            // Шукаємо ID категорій, назва яких містить ключові слова слота
            const matchedCategoryIds = allCategories
                .filter(cat => slotDef.keywords.some(kw => cat.name.toLowerCase().includes(kw)))
                .map(cat => cat.id);

            // Якщо категорія не знайдена, показуємо всі товари (fallback)
            if (matchedCategoryIds.length === 0) return allProducts;

            return allProducts.filter(p => matchedCategoryIds.includes(p.categoryId));
        }

        function openSelectionModal(slotId) {
            currentModalSlotId = slotId;
            const slotDef = configSlots.find(s => s.id === slotId);
            
            document.getElementById('modal-title').innerText = slotDef.name;
            document.getElementById('modal-search').value = '';
            
            filterModalProducts();

            const modal = document.getElementById('selection-modal');
            modal.classList.remove('hidden');
            setTimeout(() => modal.classList.remove('opacity-0'), 10);
        }

        function closeSelectionModal() {
            const modal = document.getElementById('selection-modal');
            modal.classList.add('opacity-0');
            setTimeout(() => modal.classList.add('hidden'), 300);
            currentModalSlotId = null;
        }

        function filterModalProducts() {
            if (!currentModalSlotId) return;
            
            const searchTerm = document.getElementById('modal-search').value.toLowerCase().trim();
            const eligibleProducts = getEligibleProductsForSlot(currentModalSlotId);
            
            const filtered = eligibleProducts.filter(p => p.name.toLowerCase().includes(searchTerm));
            const grid = document.getElementById('modal-products-grid');

            if (filtered.length === 0) {
                grid.innerHTML = `<div class="col-span-full text-center py-10 text-gray-400">Товарів не знайдено</div>`;
                return;
            }

            grid.innerHTML = filtered.map(p => {
                const isOutOfStock = !p.stockCount || p.stockCount <= 0;
                const isSelected = selectedBuild[currentModalSlotId]?.id === p.id;
                const warnings = checkCompatibility(p, currentModalSlotId);
                const hasWarnings = warnings.length > 0;
                
                let btnHtml = '';
                let warningHtml = '';
                if (hasWarnings) {
                    warningHtml = `<div class="mt-2 p-2 bg-red-50 border border-red-200 rounded-lg text-[11px] text-red-600 leading-tight">
                        <i class="fas fa-exclamation-triangle mr-1"></i>${warnings.join('<br><i class="fas fa-exclamation-triangle mr-1"></i>')}
                    </div>`;
                }

                if (isSelected) {
                    btnHtml = `<button disabled class="w-full mt-3 bg-green-500 text-white font-bold py-2.5 rounded-lg text-sm uppercase">Вибрано <i class="fas fa-check ml-1"></i></button>`;
                } else if (isOutOfStock) {
                    btnHtml = `<button disabled class="w-full mt-3 bg-gray-100 text-gray-400 font-bold py-2.5 rounded-lg text-sm cursor-not-allowed">Немає в наявності</button>`;
                } else if (hasWarnings) {
                    btnHtml = `<button onclick="selectPart(${p.id})" class="w-full mt-3 bg-orange-100 text-orange-600 hover:bg-orange-500 hover:text-white font-bold py-2.5 rounded-lg text-sm transition-colors uppercase tracking-wide">Додати попри це</button>`;
                } else {
                    btnHtml = `<button onclick="selectPart(${p.id})" class="w-full mt-3 bg-st-purple/10 text-st-purple hover:bg-st-purple hover:text-white font-bold py-2.5 rounded-lg text-sm transition-colors uppercase tracking-wide">Додати в збірку</button>`;
                }

                const borderClass = isSelected ? 'border-green-500 shadow-md' : (hasWarnings ? 'border-orange-300 bg-orange-50/30' : 'border-gray-200 hover:border-st-purple/30');

                return `
                <div class="bg-white rounded-xl p-4 border ${borderClass} flex flex-col h-full transition-all relative">
                    <div class="h-32 mb-3 flex items-center justify-center p-2 bg-white rounded-lg">
                        <img src="${p.imageUrl || ''}" class="max-h-full object-contain" onerror="this.src=''; this.parentElement.innerHTML='<i class=\\'fas fa-image text-gray-200 text-4xl\\'></i>'">
                    </div>
                    <div class="text-[10px] text-gray-400 uppercase font-bold mb-1">${p.manufacturerName || 'Brend'}</div>
                    <div class="font-bold text-gray-900 text-[13px] leading-snug line-clamp-2 mb-2">${p.name}</div>
                    ${warningHtml}
                    <div class="mt-auto">
                        <div class="text-lg font-black text-[#f84147]">${p.price} <span class="text-xs text-gray-400 font-bold">₴</span></div>
                        ${btnHtml}
                    </div>
                </div>`;
            }).join('');
        }

        function selectPart(productId) {
            const product = allProducts.find(p => p.id === productId);
            if (product && currentModalSlotId) {
                selectedBuild[currentModalSlotId] = product;
                renderSlots();
                closeSelectionModal();
            }
        }

        function removePart(slotId) {
            selectedBuild[slotId] = null;
            renderSlots();
        }

        function updateSummary() {
            const summaryContainer = document.getElementById('summary-items');
            const parts = Object.values(selectedBuild).filter(p => p !== null);
            
            if (parts.length === 0) {
                summaryContainer.innerHTML = '<p class="text-gray-400 text-sm italic text-center mt-8">Ви ще не обрали жодної деталі</p>';
                document.getElementById('total-price').innerText = '0';
                return;
            }

            let total = 0;
            summaryContainer.innerHTML = configSlots.map(slot => {
                const p = selectedBuild[slot.id];
                if (!p) return '';
                total += p.price;
                return `
                <div class="flex justify-between items-center text-sm py-1 border-b border-gray-50 last:border-0">
                    <span class="text-gray-500 w-1/3 truncate pr-2" title="${slot.name}">${slot.name}</span>
                    <span class="font-bold text-gray-900 w-2/3 text-right truncate pl-2" title="${p.name}">${p.name}</span>
                </div>`;
            }).join('');

            document.getElementById('total-price').innerText = total;
        }

        function buyBuild() {
            if (!IS_AUTHENTICATED) {
                document.getElementById('auth-modal-overlay').classList.remove('hidden');
                return;
            }
            
            const parts = Object.values(selectedBuild).filter(p => p !== null);
            if (parts.length === 0) {
                alert("Виберіть хоча б один компонент для збірки!");
                return;
            }

            // Додаємо всі вибрані деталі в кошик
            parts.forEach(product => {
                const existing = cart.find(i => i.id === product.id);
                if (existing) {
                    if (existing.quantity < product.stockCount) existing.quantity++;
                } else {
                    cart.push({ ...product, quantity: 1 });
                }
            });

            saveCart();
            
            // Очищаємо збірку після додавання (опціонально)
            // selectedBuild = {};
            // renderSlots();
            
            toggleCart(); // Відкриваємо кошик
        }

        // --- Стандартна логіка кошика ---
        function loadCart() {
            const saved = localStorage.getItem('smarttab_cart');
            if (saved) {
                cart = JSON.parse(saved);
                cart = cart.filter(i => {
                    const actual = allProducts.find(p => p.id === i.id);
                    if (actual) {
                        i.stockCount = actual.stockCount;
                        if (i.quantity > actual.stockCount) i.quantity = actual.stockCount;
                    }
                    return i.quantity > 0;
                });
                saveCart();
            }
        }

        function saveCart() {
            localStorage.setItem('smarttab_cart', JSON.stringify(cart));
            updateCartUI();
        }

        function updateQuantity(id, delta) {
            const item = cart.find(i => i.id === id);
            if (item) {
                const newQty = item.quantity + delta;
                const actualProduct = allProducts.find(p => p.id === id);
                const maxQty = actualProduct ? actualProduct.stockCount : item.stockCount;
                if (newQty > 0 && newQty <= maxQty) { item.quantity = newQty; saveCart(); }
                else if (newQty === 0) removeFromCart(id);
            }
        }

        function removeFromCart(id) { cart = cart.filter(i => i.id !== id); saveCart(); }

        function updateCartUI() {
            const totalItems = cart.reduce((sum, i) => sum + i.quantity, 0);
            document.getElementById('cart-count').innerText = totalItems;
            const container = document.getElementById('cart-items');
            if (cart.length === 0) {
                container.innerHTML = '<div class="text-center py-20 text-gray-400"><i class="fas fa-shopping-basket text-4xl mb-3 block"></i>Порожньо</div>';
                document.getElementById('cart-total').innerText = '0 ₴';
                return;
            }
            let total = 0;
            container.innerHTML = cart.map(i => {
                total += i.price * i.quantity;
                return `
                <div class="flex gap-4 p-3 bg-white border border-gray-100 rounded-2xl relative shadow-sm">
                    <img src="${i.imageUrl || ''}" class="w-16 h-16 object-contain rounded-lg bg-gray-50 p-1">
                    <div class="flex-1">
                        <h4 class="text-sm font-bold line-clamp-1 pr-6">${i.name}</h4>
                        <div class="text-st-purple font-black my-1">${i.price} ₴</div>
                        <div class="flex items-center gap-3">
                            <div class="flex items-center border border-gray-200 rounded-lg overflow-hidden bg-gray-50">
                                <button onclick="updateQuantity(${i.id}, -1)" class="w-7 h-7 hover:bg-gray-200 transition-colors">-</button>
                                <span class="px-2 text-xs font-bold border-x border-gray-200">${i.quantity}</span>
                                <button onclick="updateQuantity(${i.id}, 1)" class="w-7 h-7 hover:bg-gray-200 transition-colors" ${i.quantity >= i.stockCount ? 'disabled opacity-30' : ''}>+</button>
                            </div>
                        </div>
                    </div>
                    <button onclick="removeFromCart(${i.id})" class="absolute top-3 right-3 text-gray-300 hover:text-red-500 transition-colors"><i class="fas fa-trash-alt"></i></button>
                </div>`;
            }).join('');
            document.getElementById('cart-total').innerText = `${total} ₴`;
        }

        function toggleCart() {
            const panel = document.getElementById('cart-panel');
            const overlay = document.getElementById('cart-overlay');
            const isHidden = panel.classList.contains('translate-x-full');
            if (isHidden) {
                overlay.classList.remove('hidden');
                setTimeout(() => { overlay.classList.remove('opacity-0'); panel.classList.remove('translate-x-full'); }, 10);
            } else {
                panel.classList.add('translate-x-full');
                overlay.classList.add('opacity-0');
                setTimeout(() => overlay.classList.add('hidden'), 300);
            }
        }

        function closeAuthModal(e) { 
            if (e && e.target !== document.getElementById('auth-modal-overlay')) return;
            document.getElementById('auth-modal-overlay').classList.add('hidden'); 
        }

        function toggleUserMenu() {
            // no dropdown on ConfigPC, placeholder
        }

        async function loadBalance() {
            try {
                const res = await fetch('/api/balance');
                if (!res.ok) return;
                const data = await res.json();
                const badge = document.getElementById('user-balance-badge');
                if (badge) {
                    badge.textContent = data.balance.toLocaleString('uk-UA') + ' ₴';
                    badge.classList.remove('hidden');
                }
            } catch (e) {}
        }

        // --- Оформлення замовлення ---
        async function checkout() {
            if (!IS_AUTHENTICATED) {
                document.getElementById('auth-modal-overlay').classList.remove('hidden');
                return;
            }

            if (cart.length === 0) return;

            const btn = document.getElementById('checkout-btn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Обробка...';

            try {
                const res = await fetch('/api/orders', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        items: cart.map(i => ({ productId: i.id, quantity: i.quantity }))
                    })
                });

                const data = await res.json();

                if (!res.ok) {
                    alert(data.error || 'Помилка оформлення замовлення');
                    btn.disabled = false;
                    btn.innerHTML = 'Оформити замовлення';
                    return;
                }

                // Успіх
                cart = [];
                saveCart();
                
                const container = document.getElementById('cart-items');
                container.innerHTML = `
                    <div class="text-center py-12">
                        <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                            <i class="fas fa-check text-green-500 text-3xl"></i>
                        </div>
                        <h3 class="text-lg font-bold text-gray-900 mb-2">Замовлення оформлено!</h3>
                        <p class="text-gray-500 text-sm mb-1">Замовлення #${data.orderId}</p>
                        <p class="text-gray-500 text-sm">Залишок балансу: <span class="font-bold text-st-purple">${data.newBalance} ₴</span></p>
                    </div>`;
                
                btn.innerHTML = '<i class="fas fa-check mr-2"></i> Оплачено';
                btn.classList.replace('bg-st-purple', 'bg-green-500');

                // Оновлюємо бейдж балансу
                const badge = document.getElementById('user-balance-badge');
                if (badge) {
                    badge.textContent = data.newBalance.toLocaleString('uk-UA') + ' ₴';
                }
                
                setTimeout(() => {
                    btn.disabled = false;
                    btn.innerHTML = 'Оформити замовлення';
                    btn.classList.replace('bg-green-500', 'bg-st-purple');
                }, 5000);

                loadData();

            } catch (e) {
                alert('Помилка з\'єднання з сервером');
                btn.disabled = false;
                btn.innerHTML = 'Оформити замовлення';
            }
        }
    </script>
</body>
</html>