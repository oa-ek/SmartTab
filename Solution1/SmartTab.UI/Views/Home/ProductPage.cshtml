@using System.Security.Claims
@{
    Layout = null;
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var userName = isAuthenticated ? User.Identity!.Name : "";
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SmartTab | Деталі товару</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --st-purple: #6f00ff;
            --st-purple-hover: #5b00d6;
        }
        body { 
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; 
            background-color: #f8f9fa; 
        }
        .bg-st-purple { background-color: var(--st-purple); }
        .text-st-purple { color: var(--st-purple); }
        
        .loader {
            border-top-color: #6f00ff;
            animation: spinner 0.6s linear infinite;
        }
        @@keyframes spinner {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #f1f1f1; border-radius: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #c1c1c1; border-radius: 4px; }
    </style>
</head>
<body class="text-gray-800">
    <div class="min-h-screen flex flex-col">
        <header class="bg-[#212121] border-b border-gray-900 sticky top-0 z-50 shadow-md text-white">
            <div class="max-w-[1400px] mx-auto px-4 h-[70px] flex items-center justify-between gap-4">
                <div class="flex items-center gap-4 shrink-0">
                    <a href="/" class="flex items-center text-st-purple text-2xl font-bold tracking-tight cursor-pointer">
                        <i class="fas fa-layer-group mr-2 text-2xl"></i>
                        <span>SmartTab</span>
                    </a>
                </div>

                <div class="flex items-center gap-6 shrink-0">
                    @if (isAuthenticated)
                    {
                        <div class="flex items-center gap-2 text-white">
                            <i class="fas fa-user-circle text-xl text-st-purple"></i>
                            <span class="font-medium text-[15px] hidden sm:block">@userName</span>
                        </div>
                    }
                    
                    <button onclick="toggleCart()" class="flex items-center gap-2 bg-[#2a2a2a] hover:bg-[#333] border border-gray-700 px-4 py-2 rounded-lg text-white transition-colors relative">
                        <i class="fas fa-shopping-cart text-st-purple"></i>
                        <span class="font-medium text-[15px]">Кошик</span>
                        <span id="cart-count" class="absolute -top-2 -right-2 bg-st-purple text-white text-xs font-bold h-5 min-w-[20px] flex items-center justify-center rounded-full px-1 shadow">0</span>
                    </button>
                </div>
            </div>
        </header>

        <main class="max-w-[1200px] mx-auto w-full px-4 py-10">
            <div id="loading-state" class="flex flex-col items-center justify-center py-20">
                <div class="loader ease-linear rounded-full border-4 border-t-4 border-gray-200 h-12 w-12 mb-4"></div>
                <p class="text-gray-400 font-medium">Завантаження товару...</p>
            </div>

            <div id="product-content" class="hidden">
                <div class="bg-white rounded-[2.5rem] shadow-sm border border-gray-100 p-8 md:p-12 overflow-hidden">
                    <div class="flex flex-col lg:flex-row gap-16">
                        <div class="w-full lg:w-1/2 flex items-center justify-center bg-white rounded-3xl p-4">
                            <img id="product-image" src="" alt="" class="max-h-[450px] w-auto object-contain transition-transform duration-500 hover:scale-105">
                        </div>

                        <div class="w-full lg:w-1/2 flex flex-col">
                            <div id="product-mfg" class="text-st-purple font-bold text-lg uppercase tracking-widest mb-2">Бренд</div>
                            <h1 id="product-name" class="text-3xl md:text-4xl font-black text-gray-900 mb-6 leading-tight line-clamp-3">Назва товару</h1>
                            
                            <div class="flex items-center gap-4 mb-8">
                                <span id="product-stock-badge" class="px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider shadow-sm"></span>
                            </div>

                            <div class="bg-gray-50 rounded-[2rem] p-8 mb-10 border border-gray-100/50 shadow-inner">
                                <div class="text-gray-400 text-sm font-bold uppercase mb-2">Ціна зараз</div>
                                <div class="flex items-baseline gap-2">
                                    <span id="product-price" class="text-5xl font-black text-gray-900 leading-none">0</span>
                                    <span class="text-2xl font-bold text-st-purple">₴</span>
                                </div>
                            </div>

                            <div class="flex gap-4 mt-auto">
                                <button onclick="addToCartFromPage()" id="buy-btn" class="max-w-[280px] flex-1 bg-st-purple hover:bg-st-purple-hover text-white font-bold py-4 rounded-2xl transition-all shadow-lg shadow-purple-500/25 flex items-center justify-center gap-3 text-lg uppercase tracking-wider">
                                    <i class="fas fa-shopping-cart"></i>
                                    В кошик
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="mt-20">
                        <h2 class="text-2xl font-black text-gray-900 mb-10 flex items-center gap-4">
                            <span class="w-1.5 h-8 bg-st-purple rounded-full"></span>
                            Технічні характеристики
                        </h2>
                        <div id="specs-table" class="grid grid-cols-1 md:grid-cols-2 gap-x-20 gap-y-0"></div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <div id="auth-modal-overlay" class="fixed inset-0 bg-black/60 z-[80] hidden flex items-center justify-center p-4" onclick="closeAuthModal()">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm p-8 relative" onclick="event.stopPropagation()">
            <div class="text-center mb-6">
                <div class="w-16 h-16 bg-st-purple/10 rounded-full flex items-center justify-center mx-auto mb-4"><i class="fas fa-lock text-st-purple text-2xl"></i></div>
                <h3 class="text-xl font-bold text-gray-900">Потрібна авторизація</h3>
                <p class="text-gray-500 text-sm mt-2">Будь ласка, увійдіть в акаунт, щоб здійснювати покупки</p>
            </div>
            <div class="space-y-3">
                <a href="/Account/Login" class="w-full flex justify-center items-center py-3 px-4 rounded-lg font-bold text-white bg-[#6f00ff] hover:bg-[#5b00d6] transition-colors shadow-lg shadow-purple-500/30">Увійти</a>
                <button onclick="closeAuthModal()" class="w-full py-2 text-sm text-gray-400 hover:text-gray-600 transition-colors">Скасувати</button>
            </div>
        </div>
    </div>

    <div id="cart-overlay" class="fixed inset-0 bg-black/50 z-[60] hidden transition-opacity opacity-0" onclick="toggleCart()"></div>
    <div id="cart-panel" class="fixed top-0 right-0 h-full w-full sm:w-[400px] bg-white z-[70] shadow-2xl transform translate-x-full transition-transform duration-300 flex flex-col">
        <div class="p-5 border-b flex justify-between items-center bg-gray-50">
            <h2 class="text-xl font-bold text-gray-900 flex items-center gap-2"><i class="fas fa-shopping-cart text-st-purple"></i> Ваш кошик</h2>
            <button onclick="toggleCart()" class="text-gray-400 hover:text-red-500 text-xl w-8 h-8 flex items-center justify-center rounded-full hover:bg-gray-100 transition-colors"><i class="fas fa-times"></i></button>
        </div>
        <div id="cart-items" class="flex-1 p-5 overflow-y-auto custom-scrollbar space-y-4"></div>
        <div class="p-5 border-t bg-gray-50">
            <div class="flex justify-between items-center mb-4 text-lg font-bold">
                <span>Разом:</span>
                <span id="cart-total" class="text-2xl text-st-purple font-black text-red-600">0 ₴</span>
            </div>
            <button onclick="alert('Функціонал замовлення в розробці!')" class="w-full bg-st-purple hover:bg-st-purple-hover text-white py-4 rounded-xl font-black uppercase tracking-wider transition-all shadow-lg shadow-purple-500/30">Оформити замовлення</button>
        </div>
    </div>

    <script>
        const IS_AUTHENTICATED = @(isAuthenticated ? "true" : "false");
        let currentProduct = null;
        let cart = [];

        document.addEventListener('DOMContentLoaded', () => {
            const productId = window.location.pathname.split('/').pop();
            loadCart();
            if (productId && !isNaN(productId)) fetchProductData(productId);
        });

        async function fetchProductData(id) {
            try {
                const [productRes, mfgRes] = await Promise.all([
                    fetch(`/api/products/${id}`),
                    fetch('/api/manufacturers')
                ]);
                
                if (!productRes.ok) throw new Error("Товар не знайдено");
                currentProduct = await productRes.json();
                const manufacturers = await mfgRes.json();
                const mfg = manufacturers.find(m => m.id == currentProduct.manufacturerId);

                renderProduct(currentProduct, mfg);
            } catch (error) {
                showError(error.message);
            }
        }

        function renderProduct(p, mfg) {
            document.getElementById('product-name').innerText = p.name;
            document.getElementById('product-mfg').innerText = mfg ? mfg.name : 'Бренд';
            document.getElementById('product-price').innerText = p.price;
            document.getElementById('product-image').src = p.imageUrl || '';
            
            const badge = document.getElementById('product-stock-badge');
            const buyBtn = document.getElementById('buy-btn');

            if (p.stockCount > 0) {
                badge.innerText = 'В наявності';
                badge.className = 'px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider bg-green-50 text-green-500 border border-green-100';
            } else {
                badge.innerText = 'Немає в наявності';
                badge.className = 'px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider bg-red-50 text-red-500 border border-red-100';
                buyBtn.disabled = true;
                buyBtn.classList.replace('bg-st-purple', 'bg-gray-100');
                buyBtn.classList.add('text-gray-400');
            }

            const specsContainer = document.getElementById('specs-table');
            if (p.specs) {
                try {
                    const specs = typeof p.specs === 'string' ? JSON.parse(p.specs) : p.specs;
                    const entries = Array.isArray(specs) ? specs : Object.entries(specs).map(([k, v]) => ({ label: k, value: v }));
                    specsContainer.innerHTML = entries.map(s => `
                        <div class="flex justify-between py-5 border-b border-gray-50 group hover:bg-gray-50/50 transition-colors px-2">
                            <span class="text-gray-400 text-sm font-bold uppercase tracking-tight">${s.label || s.name || 'Опція'}</span>
                            <span class="text-gray-900 font-black text-sm uppercase">${s.value}</span>
                        </div>
                    `).join('');
                } catch (e) { specsContainer.innerHTML = ''; }
            }

            document.getElementById('loading-state').classList.add('hidden');
            document.getElementById('product-content').classList.remove('hidden');
        }

        // CART SYSTEM
        function loadCart() {
            const saved = localStorage.getItem('smarttab_cart');
            if (saved) { cart = JSON.parse(saved); updateCartUI(); }
        }

        function saveCart() {
            localStorage.setItem('smarttab_cart', JSON.stringify(cart));
            updateCartUI();
        }

        function addToCartFromPage() {
            if (!IS_AUTHENTICATED) {
                document.getElementById('auth-modal-overlay').classList.remove('hidden');
                return;
            }
            if (!currentProduct) return;

            const existing = cart.find(i => i.id === currentProduct.id);
            if (existing) {
                if (existing.quantity < currentProduct.stockCount) existing.quantity++;
                else { alert('Досягнуто ліміту на складі!'); return; }
            } else {
                cart.push({ ...currentProduct, quantity: 1 });
            }
            saveCart();
            toggleCart(); // Автоматичне відкриття кошика
        }

        function updateQuantity(id, delta) {
            const item = cart.find(i => i.id === id);
            if (item) {
                const newQty = item.quantity + delta;
                if (newQty > 0 && newQty <= item.stockCount) { item.quantity = newQty; saveCart(); }
                else if (newQty === 0) removeFromCart(id);
            }
        }

        function removeFromCart(id) { cart = cart.filter(i => i.id !== id); saveCart(); }

        function updateCartUI() {
            const totalItems = cart.reduce((sum, i) => sum + i.quantity, 0);
            document.getElementById('cart-count').innerText = totalItems;
            
            const container = document.getElementById('cart-items');
            if (cart.length === 0) {
                container.innerHTML = '<div class="text-center py-20 text-gray-400"><i class="fas fa-shopping-basket text-4xl mb-3 block"></i>Порожньо</div>';
                document.getElementById('cart-total').innerText = '0 ₴';
                return;
            }

            let total = 0;
            container.innerHTML = cart.map(i => {
                total += i.price * i.quantity;
                return `
                <div class="flex gap-4 p-3 bg-white border border-gray-100 rounded-2xl relative shadow-sm">
                    <img src="${i.imageUrl || ''}" class="w-16 h-16 object-contain rounded-lg bg-gray-50 p-1">
                    <div class="flex-1">
                        <h4 class="text-sm font-bold line-clamp-1 pr-6">${i.name}</h4>
                        <div class="text-st-purple font-black my-1">${i.price} ₴</div>
                        <div class="flex items-center gap-3">
                            <div class="flex items-center border border-gray-200 rounded-lg overflow-hidden bg-gray-50">
                                <button onclick="updateQuantity(${i.id}, -1)" class="w-7 h-7 hover:bg-gray-200 transition-colors">-</button>
                                <span class="px-2 text-xs font-bold border-x border-gray-200">${i.quantity}</span>
                                <button onclick="updateQuantity(${i.id}, 1)" class="w-7 h-7 hover:bg-gray-200 transition-colors" ${i.quantity >= i.stockCount ? 'disabled opacity-30' : ''}>+</button>
                            </div>
                        </div>
                    </div>
                    <button onclick="removeFromCart(${i.id})" class="absolute top-3 right-3 text-gray-300 hover:text-red-500 transition-colors"><i class="fas fa-trash-alt"></i></button>
                </div>`;
            }).join('');
            document.getElementById('cart-total').innerText = `${total} ₴`;
        }

        function toggleCart() {
            const panel = document.getElementById('cart-panel');
            const overlay = document.getElementById('cart-overlay');
            const isHidden = panel.classList.contains('translate-x-full');
            
            if (isHidden) {
                overlay.classList.remove('hidden');
                setTimeout(() => {
                    overlay.classList.remove('opacity-0');
                    panel.classList.remove('translate-x-full');
                }, 10);
            } else {
                panel.classList.add('translate-x-full');
                overlay.classList.add('opacity-0');
                setTimeout(() => overlay.classList.add('hidden'), 300);
            }
        }

        function closeAuthModal() { document.getElementById('auth-modal-overlay').classList.add('hidden'); }
        function showError(msg) { 
            document.getElementById('loading-state').innerHTML = `<div class="text-red-500 font-bold">${msg}</div><a href="/" class="text-st-purple block mt-4 underline">Повернутись на головну</a>`; 
        }
    </script>
</body>
</html>