@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Доступ заборонено - SmartTab Store</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root { --st-purple: #6f00ff; }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; }
        .text-st-purple { color: var(--st-purple); }
        .bg-st-purple { background-color: var(--st-purple); }
    </style>
</head>
<body class="bg-gray-50 text-gray-800 flex flex-col min-h-screen">
    <header class="bg-[#212121] border-b border-gray-900 text-white">
        <div class="max-w-[1400px] mx-auto px-4 h-[70px] flex items-center justify-between">
            <a href="/" class="flex items-center text-st-purple text-2xl font-bold tracking-tight">
                <i class="fas fa-layer-group mr-2 text-2xl"></i>
                <span>SmartTab</span>
            </a>
        </div>
    </header>
    <main class="flex-1 flex items-center justify-center p-8">
        <div class="text-center max-w-md">
            <div class="w-24 h-24 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-6">
                <i class="fas fa-lock text-red-500 text-4xl"></i>
            </div>
            <h1 class="text-3xl font-extrabold text-gray-900 mb-3">Доступ заборонено</h1>
            <p class="text-gray-500 mb-8">У вас немає прав для перегляду цієї сторінки.</p>
            <div class="flex gap-3 justify-center">
                <a href="/" class="px-6 py-3 bg-st-purple text-white font-bold rounded-lg hover:opacity-90 transition-opacity shadow-lg shadow-purple-500/30">
                    На головну
                </a>
                <a href="/Account/Login" class="px-6 py-3 border-2 border-gray-300 text-gray-700 font-bold rounded-lg hover:border-st-purple hover:text-st-purple transition-colors">
                    Увійти
                </a>
            </div>
        </div>
    </main>
</body>
</html>
