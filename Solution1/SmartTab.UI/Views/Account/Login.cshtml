@{
    Layout = null;
    var returnUrl = ViewData["ReturnUrl"] as string ?? "/";
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Вхід - SmartTab Store</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root { --st-purple: #6f00ff; --st-purple-hover: #5b00d6; }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; background-color: #f8f9fa; }
        .text-st-purple { color: var(--st-purple); }
        .bg-st-purple { background-color: var(--st-purple); }
        .hover\:bg-st-purple-hover:hover { background-color: var(--st-purple-hover); }
        .input-field {
            width: 100%; padding: 0.625rem 1rem;
            border: 1px solid #d1d5db; border-radius: 0.5rem;
            font-size: 0.875rem; outline: none; transition: all 0.2s;
        }
        .input-field:focus {
            border-color: var(--st-purple);
            box-shadow: 0 0 0 3px rgba(111, 0, 255, 0.1);
        }
        .checkbox-custom {
            appearance: none; background-color: #fff; margin: 0;
            width: 1.15em; height: 1.15em; border: 1px solid #d1d5db;
            border-radius: 0.2em; display: grid; place-content: center;
            cursor: pointer; transition: all 0.2s;
        }
        .checkbox-custom::before {
            content: ""; width: 0.65em; height: 0.65em; transform: scale(0);
            transition: 120ms transform ease-in-out; box-shadow: inset 1em 1em white;
            background-color: white; transform-origin: bottom left;
            clip-path: polygon(14% 44%, 0 65%, 50% 100%, 100% 16%, 80% 0%, 43% 62%);
        }
        .checkbox-custom:checked { background-color: var(--st-purple); border-color: var(--st-purple); }
        .checkbox-custom:checked::before { transform: scale(1); }
    </style>
</head>
<body class="text-gray-800 flex flex-col min-h-screen">

    <header class="bg-[#212121] border-b border-gray-900 text-white">
        <div class="max-w-[1400px] mx-auto px-4 h-[70px] flex items-center justify-between">
            <a href="/" class="flex items-center text-st-purple text-2xl font-bold tracking-tight cursor-pointer">
                <i class="fas fa-layer-group mr-2 text-2xl"></i>
                <span>SmartTab</span>
            </a>
            <a href="/" class="text-sm font-medium text-gray-300 hover:text-white transition-colors flex items-center gap-2">
                <i class="fas fa-arrow-left"></i> На головну
            </a>
        </div>
    </header>

    <main class="flex-1 flex flex-col justify-center py-12 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
        <div class="absolute top-[-10%] left-[-10%] w-96 h-96 bg-st-purple/10 rounded-full blur-3xl"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-96 h-96 bg-st-purple/10 rounded-full blur-3xl"></div>

        <div class="sm:mx-auto sm:w-full sm:max-w-md relative z-10">
            <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900">Увійти в акаунт</h2>
            <p class="mt-2 text-center text-sm text-gray-600">
                Або
                <a href="/Home/Privacy" class="font-medium text-st-purple hover:underline transition-colors">
                    зареєструйтесь, якщо ще не маєте акаунту
                </a>
            </p>
        </div>

        <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md relative z-10">
            <div class="bg-white py-8 px-4 shadow-xl border border-gray-100 sm:rounded-xl sm:px-10">
                <form class="space-y-5" onsubmit="handleLogin(event)">

                    <div>
                        <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Електронна пошта</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-envelope text-gray-400 text-sm"></i>
                            </div>
                            <input id="email" name="email" type="email" required autocomplete="email"
                                   placeholder="email@example.com" maxlength="100"
                                   class="input-field pl-10">
                        </div>
                    </div>

                    <div>
                        <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Пароль</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-lock text-gray-400 text-sm"></i>
                            </div>
                            <input id="password" name="password" type="password" required
                                   placeholder="••••••••" maxlength="64"
                                   class="input-field pl-10">
                            <button type="button" onclick="togglePassword()" class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-gray-600">
                                <i class="fas fa-eye" id="eye-icon"></i>
                            </button>
                        </div>
                    </div>

                    <div class="flex items-center justify-between">
                        <label class="flex items-center gap-2 cursor-pointer">
                            <input id="rememberMe" type="checkbox" class="checkbox-custom">
                            <span class="text-sm text-gray-700">Запам'ятати мене</span>
                        </label>
                        <a href="/Account/ForgotPassword" class="text-sm font-medium text-st-purple hover:underline">
                            Забули пароль?
                        </a>
                    </div>

                    <div class="pt-1">
                        <button type="submit" id="submit-btn"
                                class="w-full flex justify-center items-center py-3 px-4 border border-transparent rounded-lg shadow-sm text-sm font-bold text-white bg-st-purple hover:bg-st-purple-hover focus:outline-none transition-colors shadow-lg shadow-purple-500/30">
                            Увійти
                        </button>
                    </div>

                    <p class="text-center text-sm text-gray-500 pt-1">
                        Немає акаунту?
                        <a href="/Home/Privacy" class="font-medium text-st-purple hover:underline">Зареєструватися</a>
                    </p>
                </form>
            </div>
        </div>
    </main>

    <script>
        const RETURN_URL = '@Html.Raw(returnUrl)';

        function togglePassword() {
            const input = document.getElementById('password');
            const icon  = document.getElementById('eye-icon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        }

        document.querySelectorAll('input').forEach(input => {
            input.addEventListener('invalid', function () {
                this.setCustomValidity('');
                if (this.validity.valueMissing) {
                    this.setCustomValidity("Це поле обов'язкове для заповнення");
                } else if (this.validity.typeMismatch && this.type === 'email') {
                    this.setCustomValidity('Введіть дійсну адресу електронної пошти (наприклад: name@example.com)');
                } else if (this.validity.tooShort) {
                    this.setCustomValidity(`Мінімальна довжина — ${this.minLength} символів`);
                }
            });
            input.addEventListener('input', function () { this.setCustomValidity(''); });
        });

        async function handleLogin(event) {
            event.preventDefault();

            const btn = document.getElementById('submit-btn');
            btn.innerHTML = '<i class="fas fa-circle-notch fa-spin mr-2"></i> Вхід...';
            btn.disabled = true;

            const params = new URLSearchParams({
                Email:      document.getElementById('email').value,
                Password:   document.getElementById('password').value,
                RememberMe: document.getElementById('rememberMe').checked ? 'true' : 'false',
                returnUrl:  RETURN_URL
            });

            try {
                const res  = await fetch('/Account/Login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: params.toString()
                });
                const data = await res.json();

                if (data.success) {
                    btn.innerHTML = '<i class="fas fa-check mr-2"></i> Успішно!';
                    btn.classList.replace('bg-st-purple', 'bg-green-500');
                    btn.classList.replace('hover:bg-st-purple-hover', 'hover:bg-green-600');
                    setTimeout(() => window.location.href = data.redirectUrl || '/', 600);
                } else {
                    btn.innerHTML = 'Увійти';
                    btn.disabled = false;
                    showError(data.error || 'Помилка входу');
                }
            } catch {
                btn.innerHTML = 'Увійти';
                btn.disabled = false;
                showError("Помилка з'єднання з сервером");
            }
        }

        function showError(msg) {
            let el = document.getElementById('server-error');
            if (!el) {
                el = document.createElement('p');
                el.id = 'server-error';
                el.className = 'text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-4 py-2 text-center';
                document.querySelector('form').prepend(el);
            }
            el.textContent = msg;
        }
    </script>
</body>
</html>
