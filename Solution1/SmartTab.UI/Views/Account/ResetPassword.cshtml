@model SmartTab.UI.Models.ResetPasswordViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Скидання паролю - SmartTab Store</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root { --st-purple: #6f00ff; --st-purple-hover: #5b00d6; }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; background-color: #f8f9fa; }
        .text-st-purple { color: var(--st-purple); }
        .bg-st-purple { background-color: var(--st-purple); }
        .hover\:bg-st-purple-hover:hover { background-color: var(--st-purple-hover); }
        .input-field {
            width: 100%; padding: 0.625rem 1rem;
            border: 1px solid #d1d5db; border-radius: 0.5rem;
            font-size: 0.875rem; outline: none; transition: all 0.2s;
        }
        .input-field:focus {
            border-color: var(--st-purple);
            box-shadow: 0 0 0 3px rgba(111, 0, 255, 0.1);
        }
    </style>
</head>
<body class="text-gray-800 flex flex-col min-h-screen">

    <header class="bg-[#212121] border-b border-gray-900 text-white">
        <div class="max-w-[1400px] mx-auto px-4 h-[70px] flex items-center justify-between">
            <a href="/" class="flex items-center text-st-purple text-2xl font-bold tracking-tight cursor-pointer">
                <i class="fas fa-layer-group mr-2 text-2xl"></i>
                <span>SmartTab</span>
            </a>
            <a href="/Account/Login" class="text-sm font-medium text-gray-300 hover:text-white transition-colors flex items-center gap-2">
                <i class="fas fa-arrow-left"></i> Повернутись до входу
            </a>
        </div>
    </header>

    <main class="flex-1 flex flex-col justify-center py-12 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
        <div class="absolute top-[-10%] left-[-10%] w-96 h-96 bg-st-purple/10 rounded-full blur-3xl"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-96 h-96 bg-st-purple/10 rounded-full blur-3xl"></div>

        <div class="sm:mx-auto sm:w-full sm:max-w-md relative z-10">
            <div class="text-center mb-6">
                <div class="w-16 h-16 bg-st-purple/10 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i class="fas fa-lock-open text-st-purple text-2xl"></i>
                </div>
                <h2 class="text-3xl font-extrabold text-gray-900">Новий пароль</h2>
                <p class="mt-2 text-sm text-gray-600">Введіть новий пароль для вашого акаунту</p>
            </div>
        </div>

        <div class="sm:mx-auto sm:w-full sm:max-w-md relative z-10">
            <div class="bg-white py-8 px-4 shadow-xl border border-gray-100 sm:rounded-xl sm:px-10">

                <!-- Форма скидання паролю -->
                <form id="reset-form" class="space-y-5" onsubmit="handleResetPassword(event)">
                    <input type="hidden" id="token" value="@Model.Token">

                    <div>
                        <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Новий пароль</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-lock text-gray-400 text-sm"></i>
                            </div>
                            <input id="password" name="password" type="password" required minlength="6"
                                   placeholder="Мінімум 6 символів" maxlength="64"
                                   class="input-field pl-10 pr-10">
                            <button type="button" onclick="togglePwd('password','eye1')" class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-gray-600">
                                <i class="fas fa-eye" id="eye1"></i>
                            </button>
                        </div>
                    </div>

                    <div>
                        <label for="confirmPassword" class="block text-sm font-medium text-gray-700 mb-1">Підтвердження паролю</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-lock text-gray-400 text-sm"></i>
                            </div>
                            <input id="confirmPassword" name="confirmPassword" type="password" required minlength="6"
                                   placeholder="Повторіть пароль" maxlength="64"
                                   class="input-field pl-10 pr-10">
                            <button type="button" onclick="togglePwd('confirmPassword','eye2')" class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-gray-600">
                                <i class="fas fa-eye" id="eye2"></i>
                            </button>
                        </div>
                    </div>

                    <div class="pt-1">
                        <button type="submit" id="submit-btn"
                                class="w-full flex justify-center items-center py-3 px-4 border border-transparent rounded-lg shadow-sm text-sm font-bold text-white bg-st-purple hover:bg-st-purple-hover focus:outline-none transition-colors shadow-lg shadow-purple-500/30">
                            <i class="fas fa-save mr-2"></i> Зберегти новий пароль
                        </button>
                    </div>
                </form>

                <!-- Повідомлення про успіх (приховане) -->
                <div id="success-message" class="hidden text-center space-y-4">
                    <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto">
                        <i class="fas fa-check text-green-500 text-2xl"></i>
                    </div>
                    <h3 class="text-lg font-bold text-gray-900">Пароль змінено!</h3>
                    <p class="text-sm text-gray-600">Ваш пароль успішно оновлено. Тепер ви можете увійти з новим паролем.</p>
                    <a href="/Account/Login"
                       class="inline-flex items-center justify-center py-3 px-6 rounded-lg text-sm font-bold text-white bg-st-purple hover:bg-st-purple-hover transition-colors shadow-lg shadow-purple-500/30">
                        <i class="fas fa-sign-in-alt mr-2"></i> Увійти
                    </a>
                </div>
            </div>
        </div>
    </main>

    <script>
        function togglePwd(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        }

        document.querySelectorAll('input[type="password"]').forEach(input => {
            input.addEventListener('invalid', function () {
                this.setCustomValidity('');
                if (this.validity.valueMissing) {
                    this.setCustomValidity("Це поле обов'язкове для заповнення");
                } else if (this.validity.tooShort) {
                    this.setCustomValidity('Пароль має бути не менше 6 символів');
                }
            });
            input.addEventListener('input', function () { this.setCustomValidity(''); });
        });

        async function handleResetPassword(event) {
            event.preventDefault();

            const pwd = document.getElementById('password').value;
            const confirm = document.getElementById('confirmPassword').value;

            if (pwd !== confirm) {
                showError('Паролі не збігаються');
                return;
            }

            const btn = document.getElementById('submit-btn');
            btn.innerHTML = '<i class="fas fa-circle-notch fa-spin mr-2"></i> Збереження...';
            btn.disabled = true;

            const params = new URLSearchParams({
                Token: document.getElementById('token').value,
                Password: pwd,
                ConfirmPassword: confirm
            });

            try {
                const res = await fetch('/Account/ResetPassword', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: params.toString()
                });
                const data = await res.json();

                if (data.success) {
                    document.getElementById('reset-form').classList.add('hidden');
                    document.getElementById('success-message').classList.remove('hidden');
                } else {
                    btn.innerHTML = '<i class="fas fa-save mr-2"></i> Зберегти новий пароль';
                    btn.disabled = false;
                    if (data.errors) {
                        const firstError = Object.values(data.errors)[0];
                        showError(firstError);
                    } else {
                        showError(data.error || 'Помилка збереження');
                    }
                }
            } catch {
                btn.innerHTML = '<i class="fas fa-save mr-2"></i> Зберегти новий пароль';
                btn.disabled = false;
                showError("Помилка з'єднання з сервером");
            }
        }

        function showError(msg) {
            let el = document.getElementById('server-error');
            if (!el) {
                el = document.createElement('p');
                el.id = 'server-error';
                el.className = 'text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-4 py-2 text-center';
                document.getElementById('reset-form').prepend(el);
            }
            el.textContent = msg;
        }
    </script>
</body>
</html>
