@{
    Layout = null;
    var resetError = TempData["ResetError"] as string;
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Відновлення паролю - SmartTab Store</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root { --st-purple: #6f00ff; --st-purple-hover: #5b00d6; }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; background-color: #f8f9fa; }
        .text-st-purple { color: var(--st-purple); }
        .bg-st-purple { background-color: var(--st-purple); }
        .hover\:bg-st-purple-hover:hover { background-color: var(--st-purple-hover); }
        .input-field {
            width: 100%; padding: 0.625rem 1rem;
            border: 1px solid #d1d5db; border-radius: 0.5rem;
            font-size: 0.875rem; outline: none; transition: all 0.2s;
        }
        .input-field:focus {
            border-color: var(--st-purple);
            box-shadow: 0 0 0 3px rgba(111, 0, 255, 0.1);
        }
    </style>
</head>
<body class="text-gray-800 flex flex-col min-h-screen">

    <header class="bg-[#212121] border-b border-gray-900 text-white">
        <div class="max-w-[1400px] mx-auto px-4 h-[70px] flex items-center justify-between">
            <a href="/" class="flex items-center text-st-purple text-2xl font-bold tracking-tight cursor-pointer">
                <i class="fas fa-layer-group mr-2 text-2xl"></i>
                <span>SmartTab</span>
            </a>
            <a href="/Account/Login" class="text-sm font-medium text-gray-300 hover:text-white transition-colors flex items-center gap-2">
                <i class="fas fa-arrow-left"></i> Повернутись до входу
            </a>
        </div>
    </header>

    <main class="flex-1 flex flex-col justify-center py-12 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
        <div class="absolute top-[-10%] left-[-10%] w-96 h-96 bg-st-purple/10 rounded-full blur-3xl"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-96 h-96 bg-st-purple/10 rounded-full blur-3xl"></div>

        <div class="sm:mx-auto sm:w-full sm:max-w-md relative z-10">
            <div class="text-center mb-6">
                <div class="w-16 h-16 bg-st-purple/10 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i class="fas fa-key text-st-purple text-2xl"></i>
                </div>
                <h2 class="text-3xl font-extrabold text-gray-900">Відновлення паролю</h2>
                <p class="mt-2 text-sm text-gray-600">
                    Введіть email, на який зареєстровано ваш акаунт. Ми надішлемо посилання для скидання паролю.
                </p>
            </div>
        </div>

        <div class="sm:mx-auto sm:w-full sm:max-w-md relative z-10">
            <div class="bg-white py-8 px-4 shadow-xl border border-gray-100 sm:rounded-xl sm:px-10">

                <!-- Форма введення email -->
                <form id="forgot-form" class="space-y-5" onsubmit="handleForgotPassword(event)">
                    <div>
                        <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Електронна пошта</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-envelope text-gray-400 text-sm"></i>
                            </div>
                            <input id="email" name="email" type="email" required autocomplete="email"
                                   placeholder="email@example.com" maxlength="100"
                                   class="input-field pl-10">
                        </div>
                    </div>

                    <div class="pt-1">
                        <button type="submit" id="submit-btn"
                                class="w-full flex justify-center items-center py-3 px-4 border border-transparent rounded-lg shadow-sm text-sm font-bold text-white bg-st-purple hover:bg-st-purple-hover focus:outline-none transition-colors shadow-lg shadow-purple-500/30">
                            <i class="fas fa-paper-plane mr-2"></i> Надіслати посилання
                        </button>
                    </div>

                    <p class="text-center text-sm text-gray-500 pt-1">
                        Згадали пароль?
                        <a href="/Account/Login" class="font-medium text-st-purple hover:underline">Увійти</a>
                    </p>
                </form>

                <!-- Повідомлення про успіх (приховане) -->
                <div id="success-message" class="hidden text-center space-y-4">
                    <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto">
                        <i class="fas fa-check text-green-500 text-2xl"></i>
                    </div>
                    <h3 class="text-lg font-bold text-gray-900">Лист надіслано!</h3>
                    <p class="text-sm text-gray-600">
                        Якщо акаунт з цим email існує, ви отримаєте лист з посиланням для скидання паролю. Перевірте також папку "Спам".
                    </p>
                    <a href="/Account/Login" class="inline-block mt-4 text-sm font-medium text-st-purple hover:underline">
                        <i class="fas fa-arrow-left mr-1"></i> Повернутись до входу
                    </a>
                </div>
            </div>
        </div>
    </main>

    <script>
        @if (!string.IsNullOrEmpty(resetError))
        {
            <text>
            (function() {
                const el = document.createElement('p');
                el.className = 'text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-4 py-2 text-center mb-4';
                el.textContent = '@Html.Raw(resetError)';
                document.getElementById('forgot-form').prepend(el);
            })();
            </text>
        }

        document.querySelectorAll('input').forEach(input => {
            input.addEventListener('invalid', function () {
                this.setCustomValidity('');
                if (this.validity.valueMissing) {
                    this.setCustomValidity("Це поле обов'язкове для заповнення");
                } else if (this.validity.typeMismatch && this.type === 'email') {
                    this.setCustomValidity('Введіть дійсну адресу електронної пошти');
                }
            });
            input.addEventListener('input', function () { this.setCustomValidity(''); });
        });

        async function handleForgotPassword(event) {
            event.preventDefault();

            const btn = document.getElementById('submit-btn');
            btn.innerHTML = '<i class="fas fa-circle-notch fa-spin mr-2"></i> Надсилання...';
            btn.disabled = true;

            const params = new URLSearchParams({
                Email: document.getElementById('email').value
            });

            try {
                const res = await fetch('/Account/ForgotPassword', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: params.toString()
                });
                const data = await res.json();

                if (data.success) {
                    document.getElementById('forgot-form').classList.add('hidden');
                    document.getElementById('success-message').classList.remove('hidden');
                } else {
                    btn.innerHTML = '<i class="fas fa-paper-plane mr-2"></i> Надіслати посилання';
                    btn.disabled = false;
                    showError(data.error || 'Помилка надсилання');
                }
            } catch {
                btn.innerHTML = '<i class="fas fa-paper-plane mr-2"></i> Надіслати посилання';
                btn.disabled = false;
                showError("Помилка з'єднання з сервером");
            }
        }

        function showError(msg) {
            let el = document.getElementById('server-error');
            if (!el) {
                el = document.createElement('p');
                el.id = 'server-error';
                el.className = 'text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-4 py-2 text-center';
                document.getElementById('forgot-form').prepend(el);
            }
            el.textContent = msg;
        }
    </script>
</body>
</html>
